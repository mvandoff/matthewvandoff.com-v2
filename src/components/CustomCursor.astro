<style is:global>
	@media (hover: hover) and (pointer: fine) {
		:root {
			--cursor-default: url('/cursor-circle.svg') 9 9, auto;
			--cursor-external: url('/cursor-external-link.svg') 9 9, auto;
		}

		html,
		html * {
			cursor: var(--cursor-default) !important;
		}

		html a[target='_blank'],
		html a[target='_blank'] * {
			cursor: var(--cursor-external) !important;
		}

		html input,
		html textarea,
		html select,
		html [contenteditable='true'] {
			cursor: text !important;
		}
	}
</style>

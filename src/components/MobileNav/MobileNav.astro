---
import MobileMenu from 'components/MobileNav/MobileMenu.astro';
---

<div id="mobile-nav"></div>
<MobileMenu />
<button id="menu-btn" class="closed" aria-expanded="false" aria-controls="mobile-menu">[ menu ]</button>

<style is:global>
	#mobile-nav {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		background: black;
		transition: background var(--overlay-transition-time) ease;
		z-index: 10;
		justify-content: space-between;
		align-items: center;
		font-size: 26px;
		padding: 1rem;
	}
	.mobile-nav-msg-group {
		display: grid;
		align-items: center;
		justify-items: start;
		position: relative;
	}
	#menu-btn {
		position: fixed;
		right: 0.5rem;
		top: 14px;
		z-index: 9999;
		font-size: 18px;
		display: none;
	}
	#work-back-btn-mobile {
		right: 1rem;
	}
	@media (max-width: 1280px) {
		#menu-btn,
		#work-back-btn-mobile,
		.mobile-nav-msg {
			display: block;
		}
		#mobile-nav .work-nav-item {
			font-size: 18px;
			letter-spacing: 0.15rem;
		}
		.mobile-nav-msg {
			font-size: 18px;
			letter-spacing: 0.15rem;
			display: flex;
			align-items: center;
			gap: 1rem;
			white-space: nowrap;
			z-index: 999;
			grid-area: 1 / 1;
		}
		.mobile-nav-counter-wrap {
			display: inline-flex;
			align-items: baseline;
			gap: 0.3rem;
		}
		.mobile-nav-counter__slash {
			display: inline-block;
		}
		.mobile-nav-counter {
			display: inline-block;
			min-width: calc(var(--counter-digits, 1) * 1ch);
			text-align: right;
			vertical-align: baseline;
		}
		.mobile-nav-counter__value {
			display: inline-block;
		}
		.mobile-nav-msg::before {
			content: '';
			display: inline-block;
			width: 6px;
			height: 6px;
			background: currentColor;
			margin-top: 4px;
			animation: spin 4s infinite linear;
		}
	}
	@media (max-width: 767px) {
		#menu-btn {
		}
	}
	@media (max-width: 1280px) {
		#mobile-nav {
			display: flex;
		}
	}
</style>
<script>
	import { gsap } from 'gsap';

	const initMobileMenu = () => {
		const btn = document.querySelector<HTMLButtonElement>('#menu-btn');
		const menu = document.querySelector<HTMLElement>('#mobile-menu');

		if (!btn || !menu || btn.dataset.mobileMenuInit === 'true') return;
		btn.dataset.mobileMenuInit = 'true';

		const links = gsap.utils.toArray<HTMLElement>('[data-mobile-menu-link]', menu);
		const menuList = menu.querySelector<HTMLElement>('ul');
		const noiseLayer = menu.querySelector<HTMLElement>('.mobile-menu__noise');
		const warpLayers = gsap.utils.toArray<HTMLElement>('.mobile-menu__warp', menu);
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let isMenuOpen = btn.classList.contains('open');

		const setButtonState = (isOpen: boolean) => {
			btn.textContent = isOpen ? '[ close ]' : '[ menu ]';
			btn.classList.toggle('open', isOpen);
			btn.classList.toggle('closed', !isOpen);
			btn.setAttribute('aria-expanded', String(isOpen));
		};

		const setMenuVisibilityClass = (isVisible: boolean) => {
			menu.classList.toggle('open', isVisible);
			menu.classList.toggle('closed', !isVisible);
		};

		gsap.set(menu, {
			autoAlpha: 0,
			pointerEvents: 'none',
			clipPath: 'inset(0 0 100% 0)',
			backdropFilter: 'blur(0px)',
		});
		if (menuList) gsap.set(menuList, { filter: 'blur(10px)', scale: 1.025 });
		if (noiseLayer) gsap.set(noiseLayer, { autoAlpha: 0, backgroundPosition: '0px 0px' });
		gsap.set(warpLayers, {
			autoAlpha: 0,
			filter: 'blur(28px)',
			scale: 0.82,
			xPercent: (index: number) => (index % 2 === 0 ? -18 : 18),
			yPercent: (index: number) => (index % 2 === 0 ? -10 : 8),
			rotate: (index: number) => (index % 2 === 0 ? -6 : 6),
		});
		gsap.set(links, { autoAlpha: 0, yPercent: 30, filter: 'blur(8px)' });

		const menuTimeline = gsap.timeline({
			paused: true,
			defaults: { ease: 'power3.out' },
			onComplete: () => {
				setMenuVisibilityClass(true);
				gsap.set(menu, { pointerEvents: 'auto' });
			},
			onReverseComplete: () => {
				if (isMenuOpen) {
					setMenuVisibilityClass(true);
					gsap.set(menu, { pointerEvents: 'auto' });
					return;
				}
				setMenuVisibilityClass(false);
				gsap.set(menu, { pointerEvents: 'none' });
			},
		});

		menuTimeline
			.to(menu, { autoAlpha: 1, clipPath: 'inset(0 0 0% 0)', duration: 0.62, ease: 'power4.out' }, 0)
			.to(menu, { backdropFilter: 'blur(9px)', duration: 0.52 }, 0);

		if (noiseLayer) {
			menuTimeline
				.to(noiseLayer, { autoAlpha: 0.38, duration: 0.14, ease: 'none' }, 0.04)
				.to(noiseLayer, { backgroundPosition: '0px 180px', duration: 0.86, ease: 'none' }, 0)
				.to(noiseLayer, { autoAlpha: 0.18, duration: 0.28 }, 0.56);
		}

		menuTimeline.to(
			warpLayers,
			{
				autoAlpha: 0.9,
				filter: 'blur(0px)',
				scale: 1.15,
				xPercent: 0,
				yPercent: 0,
				rotate: 0,
				duration: 0.9,
				stagger: 0.05,
				ease: 'sine.out',
			},
			0.02,
		);

		if (menuList) menuTimeline.to(menuList, { filter: 'blur(0px)', scale: 1, duration: 0.42 }, 0.22);

		menuTimeline.to(links, { autoAlpha: 1, yPercent: 0, filter: 'blur(0px)', duration: 0.58, stagger: 0.08 }, 0.3);

		const setMenuState = (isOpen: boolean) => {
			isMenuOpen = isOpen;
			setButtonState(isOpen);
			menu.setAttribute('aria-hidden', String(!isOpen));
		};

		const animateMenu = (isOpen: boolean) => {
			setMenuState(isOpen);
			if (isOpen) {
				setMenuVisibilityClass(true);
				gsap.set(menu, { pointerEvents: 'auto' });
				menuTimeline.play();
				return;
			}
			gsap.set(menu, { pointerEvents: 'none' });
			menuTimeline.reverse();
		};

		const setOpenImmediate = (isOpen: boolean) => {
			setMenuState(isOpen);
			menuTimeline.pause(isOpen ? menuTimeline.duration() : 0);
			setMenuVisibilityClass(isOpen);
			gsap.set(menu, { autoAlpha: isOpen ? 1 : 0, pointerEvents: isOpen ? 'auto' : 'none' });
		};

		setOpenImmediate(isMenuOpen);

		btn.addEventListener('click', (event) => {
			event.stopPropagation();
			const nextOpenState = !isMenuOpen;
			if (prefersReducedMotion) {
				setOpenImmediate(nextOpenState);
				return;
			}
			animateMenu(nextOpenState);
		});
	};

	document.addEventListener('DOMContentLoaded', initMobileMenu, { once: true });
	document.addEventListener('astro:page-load', initMobileMenu);
</script>

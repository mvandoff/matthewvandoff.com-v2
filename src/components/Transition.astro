<div class="transition" id="transition"></div>

<style is:global>
	:root {
		--transition-bg: var(--main-950);
		--transition-block-size: var(--block-size);
	}
	.transition {
		display: grid;
		/* Must sit above all page overlays (e.g. Home `#block-grid` and `.tl-block` z-indexes). */
		z-index: 10000;
		background-color: var(--transition-bg);
		width: 100%;
		min-height: 100vh;
		position: fixed;
		inset: 0;
		grid-auto-columns: var(--transition-block-size);
		grid-auto-rows: var(--transition-block-size);
	}

	.transition-block {

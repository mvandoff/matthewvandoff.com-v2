<div class="transition" id="transition"></div>

<style is:global>
	:root {
		--transition-bg: var(--main-800);
		--transition-block-size: var(--block-size);
		--transition-logo-fade-duration: 500ms;
	}
	.transition {
		display: grid;
		/* Must sit above all page overlays (e.g. Home `#block-grid` and `.tl-block` z-indexes). */
		z-index: 10000;
		background-color: var(--transition-bg);
		width: 100%;
		min-height: 100vh;
		position: fixed;
		inset: 0;
		grid-auto-columns: var(--transition-block-size);
		grid-auto-rows: var(--transition-block-size);
	}

	.transition-block {
		position: relative;
		overflow: hidden;
		background-color: var(--transition-bg);
		width: 100%;
		height: 100%;
	}

	.transition-block--logo::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: var(--transition-logo-url);
		background-repeat: no-repeat;
		background-size: var(--transition-logo-width) var(--transition-logo-height);
		background-position: var(--transition-logo-pos-x) var(--transition-logo-pos-y);
		opacity: 0;
		transition: opacity var(--transition-logo-fade-duration) ease;
	}

	.transition--logo-no-fade .transition-block--logo::before {
		transition: none;
	}

	.transition--logo-ready .transition-block--logo::before {
		opacity: 1;
	}

	@media screen and (max-width: 1280px) {
		:root {
			--transition-block-size: 48px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.transition-block--logo::before {
			transition: none;
		}
	}
</style>
<script is:inline>
	window.setTimeout(() => {
		const transition = document.getElementById('transition');
		if (transition.dataset.transitionInitialized === 'true') return;

		console.error('Transition failed to initialize before the fallback timeout.');
		transition.style.display = 'none';
		transition.style.background = 'transparent';
		transition.querySelectorAll('.transition-block').forEach((block) => {
			block.style.opacity = '0';
			block.style.visibility = 'hidden';
		});
	}, 2000);
</script>
<script>
	import { initTransition } from 'scripts/global/initTransition';

	initTransition();
</script>

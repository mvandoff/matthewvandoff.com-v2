---
type Props = {
	company: string;
	start: string;
	end: string;
	title: string;
	description: string;
	link?: string;
	icon?: string;
};

const { start, end, title, company, description, link, icon } = Astro.props;
---

<a class="tl-block" href={link} target="_blank">
	<div class="tl-left">
		{start} – {end}
	</div>
	<div class="tl-right">
		<div class="tl-company">
			<b>{title}</b>
			<span class="tl-spacer">■</span>
			{company}
			<span class="tl-icon">{icon}</span>
		</div>

		<div class="tl-description">{description}</div>
	</div>
</a>

<style>
	.tl-block {
		font-family: 'Inter', sans-serif;
		display: flex;
		gap: 2rem;
		padding: 1.25rem;
		border-radius: 0.25rem;
		transition: all 0.25s;
		&:hover {
			background: var(--main-900);
			.tl-description {
				color: var(--main-300);
			}
			.tl-left {
				color: var(--main-400);
			}
		}
		&:first-of-type {
			/* padding-top: 0; */
			margin-top: -0.75rem;
		}
	}
	.tl-left {
		color: var(--slate-500);
		font-family: monospace;
		letter-spacing: 0.15rem;
		width: 150px;
		flex-shrink: 0;
		padding-top: 4px;
		/* text-transform: uppercase; */
		transition: all 0.15s;
	}
	.tl-right {
		display: flex;
		flex-direction: column;
		font-size: 18px;

		.tl-company {
			font-size: 18px;
			display: flex;
			gap: 0.5rem;
			color: var(--slate-300);

			.tl-icon {
				margin-left: 0.25rem;
			}
		}
		.tl-spacer {
			margin: 0 6px;
		}
		.tl-description {
			margin-top: 0.5rem;
			font-size: 15px;
			color: var(--slate-400);
			line-height: 28px;
			/* max-width: 530px; */
			transition: all 0.15s;
		}
	}
</style>

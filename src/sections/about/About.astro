---
import './background.css';
import me from 'assets/images/idea.png';
import { Image } from 'astro:assets';
import TimelineBlock from 'sections/about/TimelineBlock.astro';
import { Icon } from 'astro-icon/components';
import Corner from 'sections/about/Corner.astro';
---

<section id="about">
	<div class="left">
		<h1>matthew van doff</h1>
		<h2>software developer</h2>
		<p id="headline">Proin quis sem lacus. Vivamus non lorem nulla. Nam vel molestie est.</p>

		<div class="links">
			<a href="https://www.linkedin.com/in/matthew-vandoff/" target="_blank">
				<Icon name="fa7-brands:linkedin" />
			</a>
			<a href="https://github.com/mvandoff" target="_blank">
				<Icon name="fa7-brands:github" />
			</a>
		</div>

		<div class="img-container-outer">
			<Corner className="tl" />
			<Corner className="tr" />
			<Corner className="bl" />
			<Corner className="br" />
			<div class="img-container">
				<Image src={me} alt="picture of me" class="me" />
			</div>
		</div>
	</div>
	<div class="right">
		<h3 class="about">about</h3>
		<p class="blurb">
			Hey what's up? I'm a human software developer, one of the last of my kind. I'm based in the Raleigh-Durham area in
			North Carolina, USA and have been developing professionally for well over 4 years. I like working with all kinds
			of software, but I specialize in full stack web development.
		</p>
		<p class="blurb">
			Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus blandit fringilla lacus id sagittis. Duis
			aliquam, odio vel fermentum iaculis, metus ligula ultricies risus, et sodales metus augue eget nibh. Donec dapibus
			at est ac auctor. Phasellus rutrum scelerisque luctus. Orci varius natoque penatibus et magnis dis parturient
			montes, nascetur ridiculus mus. Cras eu risus eu eros sagittis feugiat a eget metus. Praesent neque ex, efficitur
			at libero aliquet, interdum venenatis nisi.
		</p>

		<div id="tl">
			<h3>experience</h3>
			<TimelineBlock
				company="Cyncly"
				title="Web Developer"
				start="2024"
				end="present"
				description="Worked on the frontend team for Insight, a full scale manufacturing solution, migrating a monolithic legacy application to a modern React web app as well as developing new cutting-edge features."
				link="https://www.cyncly.com/"
			/>
			<TimelineBlock
				company="Game Builds"
				icon="🪦"
				title="Full Stack Developer"
				start="2023"
				end="2024"
				description="Helped build, launch and maintain www.diablobuilds.com which was an online resource and community for the popular online video game Diablo IV, featuring an advanced character builder with in depth analytics and customization."
			/>
			<TimelineBlock
				company="Applied Visions"
				title="Software Engineer"
				start="2021"
				end="2023"
				description="Developed two key enterprise applications: a professional networking platform for the insurance industry and an AI-powered project management tool for government clients, as well as mentoring junior developers for the client."
				link="https://avi.com"
			/>
		</div>
	</div>
</section>

<style>
	#about {
		padding: 0 2rem 0 0;
		display: flex;
		flex-direction: row;
		width: 100%;
		justify-content: space-between;
		height: auto;
		gap: var(--bg-block-size);
	}
	.left,
	.right {
		padding: 8rem 0;
	}
	.left {
		--about-left-start: calc(2 * var(--bg-block-size));
		--about-left-width: calc(8 * var(--bg-block-size));

		flex: 0 0 var(--about-left-width);
		width: var(--about-left-width);
		/* max-width: 510px; */
		height: 100vh;
		margin-left: var(--about-left-start);
		position: fixed;
		top: 0;

		#headline {
			font-family: 'Inter', sans-serif;
			font-size: 16px;
			color: var(--slate-400);
			width: 350px;
			line-height: 24px;
		}

		.links {
			margin-top: 1.5rem;
			display: flex;
			gap: 0.5rem;

			svg {
				height: 2.5rem;
				width: 2.5rem;
				color: #a4a4a4;
				transition: all 0.25s ease;
				&:hover {
					color: white;
				}
			}
		}
	}
	.right {
		--about-right-end: 0px;
		--about-right-start: 0px;
		--about-right-width: calc(12 * var(--bg-block-size));

		max-width: var(--about-right-width);
		flex: 1 1 0;
		margin-right: var(--about-right-end);
		margin-left: calc(55% + var(--about-right-start));

		.blurb {
			/* width: 625px; */
			font-size: 16px;
			border-radius: 0.5rem;
			line-height: 26px;
			font-family: 'Inter', sans-serif;
			color: var(--slate-400);
			padding-left: 1rem;
		}
	}
	h1 {
		font-size: 48px;
		color: var(--slate-200);
		margin-bottom: 0;
		padding: 0;
	}
	h2 {
		color: var(--slate-200);
		font-size: 22px;
		text-align: left;
		padding: 0;
		margin-top: 0.65rem;
		align-self: baseline;
		user-select: auto;
	}
	h3 {
		color: var(--slate-200);
		margin: 0;
		padding-left: 1rem;
		margin: 1rem 0;
		font-size: 22px;
	}
	#tl {
		display: flex;
		flex-direction: column;
	}

	@media screen and (max-width: 1740px) {
		#about {
			/* padding-top: 2rem; */
		}
	}
	@media screen and (max-width: 1023px) {
	}
	@media screen and (max-width: 767px) {
	}
</style>
<style is:global>
	nav,
	h1,
	h2 {
		background: transparent !important;
	}
	.img-container-outer {
		position: relative;
		transition: all 0.5s ease;

		&:hover {
			.img-container {
				img.me {
					filter: grayscale(0.2) !important;
					opacity: 0.9 !important;
				}
			}
		}
		.corner {
			position: absolute;
			width: 35px;
			transition: all 0.5s;

			&.tl {
				rotate: 270deg;
				top: 0;
				left: 0;
			}
			&.tr {
				top: 0;
				right: 0;
			}
			&.br {
				rotate: 90deg;
				bottom: 0;
				right: 0;
			}
			&.bl {
				rotate: 180deg;
				bottom: 0;
				left: 0;
			}
		}
		.img-container {
			margin: 2rem auto;
			width: 100%;
			padding: 1.75rem 1.25rem;
			position: relative;
			display: flex;
			justify-content: center;

			img.me {
				width: 95%;
				max-width: 450px;
				opacity: 0.8;
				filter: grayscale(0.75);
				user-select: none;
				object-fit: cover;
				border-radius: 0.25rem;
				max-height: min(525px, 45vh);
				transition: 0.25s ease;
			}
		}

		&:hover {
			img {
				filter: none;
			}
			.corner {
				&.tl {
					top: -5px;
					left: -5px;
				}
				&.tr {
					top: -5px;
					right: -5px;
				}
				&.br {
					bottom: -5px;
					right: -5px;
				}
				&.bl {
					bottom: -5px;
					left: -5px;
				}
			}
		}
	}
</style>
<script>
	import { initAbout } from 'sections/about/scripts/initAbout';

	document.addEventListener('DOMContentLoaded', initAbout);
</script>

---
import './about-background.css';
import './blocks.css';
import { Icon } from 'astro-icon/components';
import Timeline from 'sections/about/Timeline.astro';
import AboutSvgFilters from 'sections/about/AboutSvgFilters.astro';
import AboutImage from 'sections/about/AboutImage.astro';
---

<section id="about">
	<div class="left">
		<h1>matthew van doff</h1>
		<h2>software developer</h2>
		<p id="headline">Proin quis sem lacus. Vivamus non lorem nulla. Nam vel molestie est.</p>

		<div class="links">
			<a href="https://www.linkedin.com/in/matthew-vandoff/" target="_blank" rel="noreferrer">
				<Icon name="fa7-brands:linkedin" />
			</a>
			<a href="https://github.com/mvandoff" target="_blank" rel="noreferrer">
				<Icon name="fa7-brands:github" />
			</a>
		</div>

		<AboutImage />
	</div>
	<div class="right">
		<div class="about-h3-container">
			<h3 class="about">about</h3>
		</div>
		<div class="blurbs">
			<p class="blurb">
				Hey what's up? I'm a human software developer, one of the last of my kind. I'm based in the Raleigh-Durham area
				in North Carolina, USA and have been developing professionally for well over 4 years. I like working with all
				kinds of software, but I specialize in full stack web development.
			</p>
			<p class="blurb">
				Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus blandit fringilla lacus id sagittis. Duis
				aliquam, odio vel fermentum iaculis, metus ligula ultricies risus, et sodales metus augue eget nibh. Donec
				dapibus at est ac auctor. Phasellus rutrum scelerisque luctus. Orci varius natoque penatibus et magnis dis
				parturient montes, nascetur ridiculus mus. Cras eu risus eu eros sagittis feugiat a eget metus. Praesent neque
				ex, efficitur at libero aliquet, interdum venenatis nisi.
			</p>
		</div>

		<div class="timeline-slot">
			<Timeline />
		</div>
	</div>

	<AboutSvgFilters />
</section>

<style is:global>
	#main-nav {
		z-index: 10;
		height: var(--bg-block-size);
		padding-top: 0;
		padding-bottom: 0;
	}
	#about,
	#main-nav {
		/* width: calc(32 * var(--bg-block-size)); */
		max-width: calc(32 * var(--bg-block-size));
	}
</style>
<style>
	#about {
		position: relative;
		margin: 0 auto;
		padding: 0;
		justify-content: space-between;
		height: auto;
		min-height: 100vh;
		/* border: 2px solid red; */
	}
	.left {
		width: calc(8 * var(--bg-block-size));
		margin-left: calc(4 * var(--bg-block-size));
		height: calc(16 * var(--bg-block-size));
		/* background: var(--main-900); */
		position: fixed;
		top: 0;
		padding: 8rem 0;

		#headline {
			font-family: 'Inter', sans-serif;
			font-size: 16px;
			color: var(--slate-400);
			width: 350px;
			line-height: 24px;
		}

		.links {
			margin-top: 1.5rem;
			display: flex;
			gap: 0.5rem;

			svg {
				height: 2.5rem;
				width: 2.5rem;
				color: #a4a4a4;
				transition: all 0.25s ease;
				&:hover {
					color: white;
				}
			}
		}
	}
	.right {
		--right-col-start: 15;
		--right-col-span: 11;
		--right-row-about: 3;
		--right-row-blurbs: 4;
		--right-row-blurbs-span: 5;
		--right-row-timeline: 9;
		--right-row-timeline-span: 10;

		position: absolute;
		top: 0;
		left: calc(var(--right-col-start) * var(--bg-block-size));
		width: calc(var(--right-col-span) * var(--bg-block-size));
		display: grid;
		grid-template-columns: repeat(var(--right-col-span), var(--bg-block-size));
		grid-auto-rows: var(--bg-block-size);
		/* background: rgb(111, 32, 3); */
		/* top: calc(2 * var(--bg-block-size)); */
		/* border: 5px solid red; */

		h3 {
			color: var(--slate-200);
			margin: 0;
			padding-left: 1rem;
			font-size: 22px;
		}
		.about-h3-container {
			/* background: green; */
			grid-column: 1 / -1;
			grid-row: var(--right-row-about) / span 1;
			height: var(--bg-block-size);
			width: 100%;
			display: flex;
			align-items: center;
		}

		.blurbs {
			/* background: red; */
			grid-column: 1 / -1;
			grid-row: var(--right-row-blurbs) / span var(--right-row-blurbs-span);
			height: calc(var(--right-row-blurbs-span) * var(--bg-block-size));
			.blurb {
				font-size: 16px;
				border-radius: 0.5rem;
				line-height: 26px;
				font-family: 'Inter', sans-serif;
				color: var(--slate-400);
				padding-left: 1rem;
			}
		}

		.timeline-slot {
			grid-column: 1 / -1;
			grid-row: var(--right-row-timeline) / span var(--right-row-timeline-span);
		}
	}
	h1,
	h2,
	h3 {
		background: transparent;
	}
	h1 {
		font-size: 48px;
		color: var(--slate-200);
		margin-bottom: 0;
		padding: 0;
	}
	h2 {
		color: var(--slate-200);
		font-size: 22px;
		text-align: left;
		padding: 0;
		margin-top: 0.65rem;
		align-self: baseline;
		user-select: auto;
	}

	@media screen and (max-width: 1740px) {
		#about {
			/* padding-top: 2rem; */
		}
	}
	@media screen and (max-width: 1023px) {
	}
	@media screen and (max-width: 767px) {
	}
</style>

<script>
	import { initAbout } from 'sections/about/scripts/initAbout';

	document.addEventListener('DOMContentLoaded', initAbout);
</script>

---
import me from 'assets/images/me.webp';
import { Image } from 'astro:assets';
import TimelineBlock from 'sections/about/TimelineBlock.astro';
---

<section id="about">
	<div class="left">
		<Image src={me} alt="picture of me" class="me" />
	</div>
	<div class="right">
		<!-- <p class="blurb">
			Hey what's up? I'm a human software developer, one of the last of my kind. I've been doing this professionally for
			almost 5 years. I like working with all kinds of software, but I specialize in full stack web development. That
			was, until the AI took over. All hail our robot overlords!
		</p> -->

		<div id="tl">
			<TimelineBlock
				company="Cyncly"
				title="Web Developer"
				start="2024"
				end="present"
				description="Worked on the frontend team for Insight, a cutting-edge manufacturing solution, migrating a monolithic legacy application to a modern React web app as well as developing new features."
				link="https://www.cyncly.com/"
			/>
			<TimelineBlock
				company="Game Builds"
				icon="🪦"
				title="Full Stack Developer"
				start="2023"
				end="2024"
				description="Helped build, launch and maintain www.diablobuilds.com which was an online resource and community for the popular online video game Diablo IV, featuring an advanced character builder with in depth analytics and customization."
			/>
			<TimelineBlock
				company="Applied Visions"
				title="Software Engineer"
				start="2021"
				end="2023"
				description="Developed two key enterprise applications: a professional networking platform for the insurance industry and an AI-powered project management tool for government clients, as well as mentoring junior developers for the client."
				link="https://avi.com"
			/>
		</div>
	</div>
</section>
<style>
	#about {
		padding: 6rem 2rem;
		display: flex;
		flex-direction: row;
		width: 100%;
		justify-content: space-between;
	}
	#tl {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 25vh;
		/* padding-bottom: 200px; */
	}
	.left,
	.right {
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.left {
		justify-content: center;
		align-items: center;
	}
	.right {
		align-items: center;
	}
	img.me {
		width: auto;
		height: auto;
		max-width: 100%;
		object-fit: scale-down;
		border-radius: 0.5rem;
		max-height: 500px;
	}
	.blurb {
		width: 500px;
		font-size: 22px;
		border-radius: 0.5rem;
		line-height: 3rem;
		font-family: 'Inter', sans-serif;
		padding: 2rem;
	}
</style>

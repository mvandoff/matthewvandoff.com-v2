---
import me from 'assets/images/idea.png';
import { Image } from 'astro:assets';
import Corner from 'sections/about/Corner.astro';
---

<div class="img-container-outer">
	<Corner className="tl" />
	<Corner className="tr" />
	<Corner className="bl" />
	<Corner className="br" />
	<div class="img-container">
		<div class="me-distort" data-scroll-distort="me">
			<Image src={me} alt="picture of me" class="me" />
		</div>
	</div>
</div>

<style is:global>
	.img-container-outer {
		position: relative;
		transition: all 0.5s ease;

		&:hover {
			.img-container {
				img.me {
					--about-me-grayscale: 0.2;
					--about-me-opacity: 0.9;
				}
			}
		}
		.corner {
			position: absolute;
			width: 35px;
			transition: all 0.5s;

			&.tl {
				rotate: 270deg;
				top: 0;
				left: 0;
			}
			&.tr {
				top: 0;
				right: 0;
			}
			&.br {
				rotate: 90deg;
				bottom: 0;
				right: 0;
			}
			&.bl {
				rotate: 180deg;
				bottom: 0;
				left: 0;
			}
		}
		.img-container {
			margin: 2rem auto;
			width: 100%;
			padding: 1.75rem 1.25rem;
			position: relative;
			display: flex;
			justify-content: center;

			.me-distort {
				--about-scroll-blur: 0px;
				width: 100%;
				display: flex;
				justify-content: center;
				filter: url(#about-scroll-distort);
				will-change: filter;
			}

			img.me {
				width: 95%;
				max-width: 450px;
				--about-me-grayscale: 0.75;
				--about-me-opacity: 0.8;
				opacity: var(--about-me-opacity);
				filter: grayscale(var(--about-me-grayscale)) blur(var(--about-scroll-blur));
				user-select: none;
				object-fit: cover;
				border-radius: 0.25rem;
				max-height: min(525px, 45vh);
				transition:
					filter 0.25s ease,
					opacity 0.25s ease;
				will-change: filter;
			}
		}

		&:hover {
			.corner {
				&.tl {
					top: -5px;
					left: -5px;
				}
				&.tr {
					top: -5px;
					right: -5px;
				}
				&.br {
					bottom: -5px;
					right: -5px;
				}
				&.bl {
					bottom: -5px;
					left: -5px;
				}
			}
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#about .me-distort {
			filter: none;
			transform: none;
		}
	}
</style>

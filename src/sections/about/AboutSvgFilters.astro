<svg class="about-svg-filters" aria-hidden="true" focusable="false">
	<defs>
		<filter id="about-scroll-distort" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
			<feTurbulence
				id="about-scroll-turbulence"
				type="fractalNoise"
				baseFrequency="0.01 0.05"
				numOctaves="1"
				seed="2"
				stitchTiles="stitch"
				result="noise"></feTurbulence>
			<feComponentTransfer in="noise" result="noisePoster">
				<feFuncR type="discrete" tableValues="0.2 0.5 0.8"></feFuncR>
				<feFuncG type="discrete" tableValues="0.2 0.5 0.8"></feFuncG>
				<feFuncB type="discrete" tableValues="0.2 0.5 0.8"></feFuncB>
			</feComponentTransfer>
			<feDisplacementMap
				id="about-scroll-displacement"
				in="SourceGraphic"
				in2="noisePoster"
				scale="0"
				xChannelSelector="R"
				yChannelSelector="G"></feDisplacementMap>
		</filter>
	</defs>
</svg>

<style>
	.about-svg-filters {
		position: absolute;
		width: 0;
		height: 0;
		overflow: hidden;
	}
</style>

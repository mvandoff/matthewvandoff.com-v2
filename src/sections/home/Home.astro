---
import './styles/shared/blocks.css';
import './styles/desktop/home-global.css';
import './styles/desktop/home-layout.css';
import './styles/mobile/mb-blocks.css';
import './styles/mobile/mb-scroll-tile.css';
import './styles/mobile/mb-intro-container-background.css';
import './styles/mobile/mb-home-global.css';
import './styles/mobile/mb-home-layout.css';
import HomeHero from 'sections/home/components/HomeHero.astro';
import HomeAbout from 'sections/home/components/HomeAbout.astro';
import HomeSvgFilters from 'sections/home/components/HomeSvgFilters.astro';
---

<section id="home">
	<div id="block-grid" aria-hidden="true"></div>
	<div class="home-content">
		<HomeHero />
		<HomeAbout />
		<HomeSvgFilters />
	</div>
</section>

<script>
	import { initAboutBtn } from 'sections/home/scripts/initAboutBtn';
	import { initHome } from 'sections/home/scripts/initHome';
	import { initHomeMobileNav } from 'sections/home/scripts/initHomeMobileNav';

	document.addEventListener('DOMContentLoaded', () => {
		initHomeMobileNav();
		initHome();
		initAboutBtn();
	});
</script>

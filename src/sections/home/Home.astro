---
import './blocks.css';
import './mb-scroll-tile.css';
import './intro-container-background.css';
import Timeline from 'sections/home/Timeline.astro';
import HomeSvgFilters from 'sections/home/HomeSvgFilters.astro';
import HomeImage from 'sections/home/HomeImage.astro';
import SocialLink from 'sections/home/SocialLink.astro';
import MVDLogo from 'components/MVDLogo.astro';
import MobileTimeline from 'sections/home/mobile/MobileTimeline.astro';
import { Icon } from 'astro-icon/components';
import keyboardCat from 'assets/gif/keyboard-cat.gif';
import kidA from 'assets/images/kid-a.jpg';
---

<section id="home">
	<div id="block-grid" aria-hidden="true"></div>
	<div class="home-content">
		<div class="screen-hero screen" data-mobile-nav-label="welcome">
			<div class="left-image-layer left-grid">
				<div class="left-image">
					<HomeImage />
				</div>
			</div>
			<div class="left left-grid intro-container">
				<div class="left-intro">
					<h1>
						matthew <span class="last-name">van&nbsp;doff</span>
					</h1>
					<h2>software developer</h2>
					<p id="headline">Proin quis sem lacus. Vivamus non lorem nulla. Nam vel molestie est.</p>
				</div>

				<div class="left-links links">
					<SocialLink
						href="https://www.linkedin.com/in/matthew-vandoff/"
						icon="fa7-brands:linkedin"
						label="LinkedIn"
						brand="linkedin"
					/>
					<SocialLink href="https://github.com/mvandoff" icon="fa7-brands:github" label="GitHub" brand="github" />
				</div>
			</div>
			<a class="mb-social-link" data-brand="li" href="https://www.linkedin.com/in/matthew-vandoff/">
				<span class="mb-social-brand-icon" aria-hidden="true">
					<Icon name="fa7-brands:linkedin" id="mb-li-icon" />
				</span>
				<span class="mb-social-label">LinkedIn</span>
			</a>
			<a class="mb-social-link" data-brand="gh" href="https://github.com/mvandoff">
				<span class="mb-social-brand-icon" aria-hidden="true">
					<Icon name="fa7-brands:github" id="mb-gh-icon" />
				</span>
				<span class="mb-social-label">GitHub</span>
			</a>
			<div id="mb-animated-tile" class="mb-tile"></div>
			<div id="mb-copy-tile" class="mb-tile" style={`--mb-copy-tile-bg: url('${kidA.src}')`}>everything in it's right place</div>
			<!-- <div id="mb-logo-tile" class="mb-tile" aria-hidden="true">
				<MVDLogo />
			</div> -->
			<!-- <div id="mb-scroll-tile" class="mb-tile">
				<button class="mb-scroll-cue" type="button" aria-label="Scroll down">
				<span class="mb-scroll-cue__chevrons" aria-hidden="true">
					<span class="mb-scroll-cue__chevron"><Icon name="heroicons:chevron-down" /></span>
					<span class="mb-scroll-cue__chevron"><Icon name="heroicons:chevron-down" /></span>
					<span class="mb-scroll-cue__chevron"><Icon name="heroicons:chevron-down" /></span>
				</span>
			</button>
			</div> -->
			<div id="mb-gif-tile" class="mb-tile">
				<img src={keyboardCat.src} alt="Keyboard cat playing a keyboard" loading="lazy" decoding="async" />
			</div>
			<div id="mb-down-tile" class="mb-tile">
				<Icon name="heroicons:chevron-down-16-solid" aria-hidden="true" />
			</div>
		</div>
		<div class="screen-about screen" data-mobile-nav-label="home-me">
			<div class="right">
				<div class="home-h3-container">
					<h3 class="home">about</h3>
				</div>
				<div class="blurbs">
					<p class="blurb">
						Hey what's up? I'm a human software developer, one of the last of my kind. I'm based in the Raleigh-Durham
						area in North Carolina, USA and have been developing professionally for well over 4 years. I like working
						with all kinds of software, but I specialize in full stack web development.
					</p>
					<p class="blurb">
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus blandit fringilla lacus id sagittis. Duis
						aliquam, odio vel fermentum iaculis, metus ligula ultricies risus, et sodales metus augue eget nibh. Donec
						dapibus at est ac auctor. Phasellus rutrum scelerisque luctus. Orci varius natoque penatibus et magnis dis
						parturient montes, nascetur ridiculus mus. Cras eu risus eu eros sagittis feugiat a eget metus. Praesent
						neque ex, efficitur at libero aliquet, interdum venenatis nisi.
					</p>
				</div>
				<div class="timeline-slot">
					<Timeline />
				</div>
			</div>
		</div>
		<!-- <MobileTimeline /> -->

		<HomeSvgFilters />
	</div>
</section>
<style>
	/* Mobile "bento" tile positions (grid-row/grid-column). */
	@media screen and (max-width: 1280px) {
		.screen-hero {
			.left-image-layer {
				grid-column: 3 / -1;
				grid-row: 1 / 12;
			}
			.intro-container {
				grid-column: 3 / -1;
				grid-row: 13 / 26;
			}
			#mb-animated-tile {
				grid-column: 1 / 2;
				grid-row: 1 / 26;
			}
			#mb-scroll-tile {
				grid-column: -4 / -1;
				grid-row: 27 / -1;
			}
			.mb-social-link[data-brand='li'] {
				grid-column: 1 / span 5;
				grid-row: 27 / span 5;
			}
			.mb-social-link[data-brand='gh'] {
				grid-column: 7 / span 5;
				grid-row: 27 / span 5;
			}
			#mb-logo-tile {
				grid-column: 14 / 19;
				grid-row: 27 / -1;
			}
			#mb-gif-tile {
				grid-column: 1 / span 11;
				grid-row: 33 / span 4;
				/* border: 1px solid white; */
				border-radius: var(--home-border-radius);
			}
			#mb-copy-tile {
				grid-column: 1 / -4;
				grid-row: 38 / span 2;
			}
			#mb-down-tile {
				grid-column: -3 / span 2;
				grid-row: 38 / span 2;
			}
		}

		.screen-about .right {
			grid-column: 2 / -2;
			grid-row: 1 / -1;
		}
	}
</style>
<style is:global>
	html,
	body,
	main {
		overflow: hidden;
		background-color: var(--neutral-950);
		background-image:
			radial-gradient(120% 120% at 12% 0%, rgba(255, 255, 255, 0.04), transparent 60%),
			radial-gradient(130% 130% at 85% 10%, rgba(99, 102, 241, 0.08), transparent 55%);
	}
	#main-nav {
		z-index: 10;
		height: var(--block-size);
		padding-top: 0;
		padding-bottom: 0;
		background: #0000004f;
	}
	#home {
		max-width: none;
		width: 100%;

		.screen {
			display: contents;
		}
	}
	.home-content,
	#main-nav {
		max-width: calc(32 * var(--block-size));
	}
	@media screen and (max-width: 1280px) {
		#home {
			.screen {
				display: block;
			}
		}
	}
</style>
<style>
	#home {
		margin-top: var(--block-size) !important;
		overflow: auto;
		overflow-anchor: none;
		position: relative;
		margin: 0 auto;
		padding: 0;
		justify-content: space-between;
		/* height: auto; */
		min-height: 100vh;
		--left-col-span: 7;
		--right-col-span: 10;
		--content-gap: 3;
		--edge-gap: 1;
		--layout-width: calc(
			(var(--left-col-span) + var(--right-col-span) + var(--content-gap) + (var(--edge-gap) * 2)) * var(--block-size)
		);
		--layout-left: calc((100vw - var(--layout-width)) / 2);
		--left-row-intro: 3;
		--left-row-intro-span: 4;
		--left-row-image: 6;
		--left-row-image-span: 7;
		--left-row-links: 14;
		--left-row-links-span: 1;
		/* border: 2px solid red; */
	}
	.home-content {
		position: relative;
		margin: 0;
		margin-left: var(--layout-left);
		width: var(--layout-width);
		min-height: 100%;
		padding-bottom: 8rem;
	}
	.mb-tile {
		display: none;
	}
	.left-grid {
		width: calc(var(--left-col-span) * var(--block-size));
		position: fixed;
		top: 0;
		left: calc(var(--layout-left) + (var(--edge-gap) * var(--block-size)));
		display: grid;
		grid-template-columns: repeat(var(--left-col-span), var(--block-size));
		grid-auto-rows: var(--block-size);
	}
	.left-image-layer {
		z-index: 4;
	}
	.left {
		z-index: 6;
		pointer-events: none;
		h1,
		h2 {
			background: transparent;
			margin: 0;
		}
		h1 {
			font-size: 48px;
			color: var(--neutral-200);
			padding: 0;
		}
		h2 {
			color: var(--neutral-200);
			font-size: 22px;
			text-align: left;
			padding: 0;
			user-select: auto;
			margin-top: 4px;
		}
		#headline {
			font-family: 'Inter', sans-serif;
			font-size: 16px;
			color: var(--neutral-400);
			width: 360px;
			line-height: 24px;
			margin: 8px 0 0 0;
		}
	}
	.left-intro {
		grid-column: 1 / -1;
		grid-row: var(--left-row-intro) / span var(--left-row-intro-span);
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		gap: 0.5rem;
		pointer-events: auto;
	}
	.left-image {
		grid-column: 1 / -1;
		grid-row: var(--left-row-image) / span var(--left-row-image-span);
		display: flex;
		align-items: stretch;
	}
	.left-image :global(.img-container-outer) {
		width: 100%;
	}
	.left-image :global(.img-container) {
		margin: 0;
	}
	.left-links {
		grid-column: 1 / -1;
		grid-row: var(--left-row-links) / span var(--left-row-links-span);
		display: grid;
		position: relative;
		z-index: 6;
		grid-template-columns: repeat(var(--left-col-span), var(--block-size));
		grid-template-rows: var(--block-size);
		align-items: center;
		margin-top: -32px;
		pointer-events: auto;
	}
	.mb-social-link {
		display: none;
	}
	.left-links :global(.social-link) {
		width: 100%;
		height: 100%;
	}
	.left-links :global(.social-link:nth-child(1)) {
		grid-column: 1 / span 3;
	}
	.left-links :global(.social-link:nth-child(2)) {
		grid-column: 4 / span 3;
		margin-left: calc(var(--block-size) / 4);
	}
	.right {
		--right-col-start: calc(var(--left-col-span) + var(--content-gap) + var(--edge-gap));
		--right-row-home: 2;
		--right-row-blurbs: 3;
		--right-row-blurbs-span: 5;
		--right-row-timeline: 8;
		--right-row-timeline-span: 10;

		margin-left: calc(var(--right-col-start) * var(--block-size));
		width: calc(var(--right-col-span) * var(--block-size));
		display: grid;
		grid-template-columns: repeat(var(--right-col-span), var(--block-size));
		grid-auto-rows: var(--block-size);
		padding-bottom: 8rem;
		padding-right: var(--block-size);
		/* background: rgb(111, 32, 3); */
		/* border: 5px solid red; */

		h3 {
			color: var(--neutral-200);
			margin: 0;
			padding-left: 1rem;
			font-size: 22px;
		}
		.home-h3-container {
			/* background: green; */
			grid-column: 1 / -1;
			grid-row: var(--right-row-home) / span 1;
			height: var(--block-size);
			width: 100%;
			display: flex;
			align-items: center;
		}
		.blurbs {
			/* background: red; */
			grid-column: 1 / -1;
			grid-row: var(--right-row-blurbs) / span var(--right-row-blurbs-span);
			height: calc(var(--right-row-blurbs-span) * var(--block-size));

			.blurb {
				font-size: 16px;
				border-radius: 0.5rem;
				line-height: 26px;
				font-family: 'Inter', sans-serif;
				color: var(--neutral-400);
				padding-left: 1rem;
			}
		}
		.timeline-slot {
			grid-column: 1 / -1;
			grid-row: var(--right-row-timeline) / span var(--right-row-timeline-span);
		}
	}

	@media screen and (max-width: 1408px) {
		#home {
			--content-gap: 2;
		}
	}
	@media screen and (max-width: 1344px) {
		#home {
			--content-gap: 1;
		}
	}
	@media screen and (max-width: 1280px) {
		:root {
			--mobile-nav-height: 48px;
			--full-width: calc(round(down, 100vw, var(--block-size)) - (var(--block-size) * 2));
			--total-blocks: round(up, calc(100vw / var(--block-size)));
			--home-image-inset: 0 !important;
			--grid-gap: 12px;
			--home-border-radius: 4px;
		}
		:global(#mobile-nav) {
			height: var(--mobile-nav-height);
			margin: 0 auto;
			/* background: yellow; */
		}

		.mb-tile {
			display: block;
			height: 100%;
			width: 100%;
			border-radius: var(--home-border-radius);
		}
		#home {
			--content-gap: 0;
			--edge-gap: 0;
			--layout-left: 0;

			margin-top: var(--mobile-nav-height) !important;
			scroll-snap-type: y mandatory;

			.home-content {
				box-sizing: border-box;
				width: var(--full-width);
				max-width: none;
				margin: 0 auto;
				/* background: red; */
			}
			.screen {
				height: calc(100dvh - var(--mobile-nav-height));
				width: min(100%, calc(var(--block-size) * 40));
				margin: 0 auto;
				/* border: 1px solid yellow; */
				margin-top: var(--mobile-nav-height);
				scroll-snap-align: start;
				scroll-snap-stop: always;
				box-sizing: border-box;
				display: grid;
				grid-template-columns: repeat(auto-fill, var(--block-size));
				grid-template-rows: repeat(auto-fill, var(--block-size));
				/* row-gap: var(--grid-gap); */
				/* column-gap: var(--grid-gap); */

				.left-grid {
					position: relative;
					width: 100%;
					grid-template-columns: none;
					grid-auto-rows: auto;
				}
			}
			.screen-hero {
				--hero-border: rgba(255, 255, 255, 0.09);

				.left-image-layer {
					display: block;

					.left-image {
						height: 100%;
						width: 100%;

						.img-container {
							padding: 0;
							img {
								opacity: 0.8;
								/* border-radius: 0; */
							}
						}
					}
				}
				.intro-container {
					/* background: rgb(8, 8, 8); */
					padding: clamp(14px, 4vw, 16px);
					border-radius: var(--home-border-radius);

					.left-intro {
						gap: 0.85rem;
					}
					h1 {
						width: 100%;
						padding: 0;
						background: transparent;
						border: 0;
						border-radius: 0;
						font-size: clamp(34px, 8vw, 44px);
						line-height: 0.95;
						letter-spacing: 0.005em;
					}
					h2 {
						padding: 0;
						background: transparent;
						border: 0;
						border-radius: 0;
						margin-top: -2px;
						font-family: 'Inter', sans-serif;
						font-size: 12px;
						letter-spacing: 0.22rem;
						text-transform: uppercase;
						color: rgba(226, 232, 240, 0.82);
						width: max-content;
					}
					.last-name {
						white-space: nowrap;
						display: inline-block;
					}
					#headline {
						margin-top: 0;
						padding-top: 0.9rem;
						border-top: 1px solid rgba(255, 255, 255, 0.07);
						border-radius: 0;
						background: transparent;
						box-shadow: none;
						line-height: 1.6;
					}
				}
				#mb-animated-tile {
					/* border: 1px solid white; */

					canvas {
						border-radius: var(--home-border-radius);
					}
				}
				#mb-copy-tile {
					--mb-copy-tile-dim: 0.7;

					background-color: var(--main-1k);
					display: flex;
					justify-content: center;
					align-items: center;
					padding: 0.5rem;
					font-family: 'inter';
					letter-spacing: 0.25rem;
					font-size: 12px;
					background-image:
						linear-gradient(rgba(0, 0, 0, var(--mb-copy-tile-dim, 0)), rgba(0, 0, 0, var(--mb-copy-tile-dim, 0))),
						var(--mb-copy-tile-bg);
					background-position: left 50% top 48%;
					color: var(--neutral-100);
				}
				.mb-social-link {
					--mb-social-radial-x: 0%;
					--mb-social-radial-y: 0%;

					height: 100%;
					width: 100%;
					border-radius: var(--home-border-radius);
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: space-between;
					padding: 0.5rem;
					position: relative;
					background-color: var(--main-1k);

					&::before {
						content: '';
						position: absolute;
						border-radius: var(--home-border-radius);
						inset: 0;
						background:
							radial-gradient(
								120% 120% at var(--mb-social-radial-x) var(--mb-social-radial-y),
								rgba(255, 255, 255, 0.08),
								transparent 55%
							),
							linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 62%);
						pointer-events: none;
					}
					.mb-social-label {
						font-family: 'Inter', sans-serif;
						font-size: 10px;
						letter-spacing: 0.15em;
						/* text-transform: lowercase; */
						color: var(--neutral-400);
					}
				}
				.mb-social-link[data-brand='li'] {
					--mb-social-radial-x: 100%;
				}
			}
		}
		:root {
			--mb-social-icon-size: 48px;
		}
		:global(.mb-social-link svg) {
			height: var(--mb-social-icon-size);
			width: var(--mb-social-icon-size);
			color: var(--neutral-300);
		}
		#mb-down-tile {
			/* display: none; */
			display: flex;
			font-size: 28px;
			background: var(--main-1k);
			justify-content: center;
			align-items: center;
			background: var(--neutral-400);
			color: var(--neutral-100);
		}
		#mb-gif-tile {
			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: inherit;
			}
		}
		#mb-logo-tile {
			/* border: 1px solid white; */
			background: #80734f;
			display: grid;
			place-items: center;
			padding: calc(var(--block-size) * 0.5);
		}
		#mb-logo-tile :global(.mvd-logo) {
			display: block;
			width: auto;
			height: min(100%, calc(var(--block-size) * 6));
			max-width: 200%;
			transform: rotate(-90deg);
			transform-origin: center;
			fill: white;
		}

		.left-links {
			display: none;
		}
		.right {
			margin-left: 0;
			width: 100%;
			display: flex;
			flex-direction: column;
			justify-content: end;
			gap: calc(var(--block-size) * 0.5);
			padding-right: 0;
			padding-bottom: 0;
			padding-bottom: calc(var(--block-size) * 2);
		}
		.right .home-h3-container,
		.right .blurbs,
		.right .timeline-slot {
			grid-column: auto;
			grid-row: auto;
			height: auto;
		}
		.right .home-h3-container {
			display: none;
		}
		.right h3,
		.right .blurbs .blurb {
			padding-left: 0;
		}
		.left #headline {
			width: 100%;
			max-width: 32rem;
		}
	}
	@media screen and (max-width: 1023px) {
	}
	@media screen and (max-width: 767px) {
	}
</style>

<script>
	import { initHome } from 'sections/home/scripts/initHome';
	import { initHomeMobileNav } from 'sections/home/scripts/initHomeMobileNav';
	import { initHomeScrollCue } from 'sections/home/scripts/initHomeScrollCue';
	import { initThree } from 'sections/home/scripts/initThree';

	document.addEventListener('DOMContentLoaded', () => {
		initHomeMobileNav();
		initHome();
		initHomeScrollCue();
		initThree();
	});
</script>

---
import { Icon } from 'astro-icon/components';

type FocusCorner = 'ne' | 'nw' | 'se' | 'sw';

type Props = {
	href?: string;
	icon: string;
	label: string;
	focusCorner?: FocusCorner;
	id?: string;
	className?: string;
	type?: 'standard' | 'external' | 'internal' | 'scroll';
};

const { id, className, type = 'standard', href, icon, label, focusCorner = 'nw' } = Astro.props as Props;
const cornerVars: Record<FocusCorner, { radialX: string; radialY: string; linearDir: string }> = {
	nw: { radialX: '0%', radialY: '0%', linearDir: 'bottom right' },
	ne: { radialX: '100%', radialY: '0%', linearDir: 'bottom left' },
	sw: { radialX: '0%', radialY: '100%', linearDir: 'top right' },
	se: { radialX: '100%', radialY: '100%', linearDir: 'top left' },
};
const { radialX, radialY, linearDir } = cornerVars[focusCorner];
const styleVars = `--mb-tile-radial-x: ${radialX}; --mb-tile-radial-y: ${radialY}; --mb-tile-linear-dir: ${linearDir};`;
const Tag = href ? 'a' : 'button';
const labelId = id ? `${id}-label` : undefined;

const ICONS = {
	external: 'heroicons:arrow-small-up-20-solid',
	internal: 'heroicons:arrow-small-up-20-solid',
	scroll: 'heroicons:arrow-small-up-20-solid',
};
---

<Tag
	id={id}
	class:list={[className, 'tile-btn mb-tile-surface']}
	aria-labelledby={labelId}
	style={styleVars}
	{...href ? { href } : { type: 'button' }}
>
	{
		type !== 'standard' && (
			<span class="badge-icon" data-type={type}>
				<Icon name={ICONS[type]} />
			</span>
		)
	}
	<span class="mb-social-brand-icon" aria-hidden="true">
		<Icon name={icon} />
	</span>
	<span class="mb-social-label" id={labelId}>{label}</span>
</Tag>

<style>
	:global(
		.mb-social-label {
			font-family: 'Inter', sans-serif;
			font-size: 10px;
			letter-spacing: 0.15em;
			color: var(--neutral-400);
			text-transform: lowercase;
		})
		
	.tile-btn {
		--icon-size: 38px;
		--badge-icon-size: 18px;

		display: none;
		flex-direction: column;
		align-items: center;
		justify-content: space-around;
		position: relative;
		/* z-index: 10; */

		.mb-social-brand-icon {
			height: var(--icon-size);
			color: var(--neutral-300);

			svg {
				height: var(--icon-size);
				width: var(--icon-size);
			}
		}
		.badge-icon {
			position: absolute;
			top: -1px;
			right: 3px;
			width: var(--badge-icon-size);
			color: var(--neutral-600);

			svg {
				width: var(--badge-icon-size);
				height: var(--badge-icon-size);
			}

			&[data-type='external'] {
				rotate: 45deg;
			}
			&[data-type='internal'] {
				rotate: 90deg;
				top: -2px;
			}
			&[data-type='scroll'] {
				rotate: 180deg;
				top: -3px;
				right: 1px;
			}
		}
		&#work-btn {
			--icon-size: 34px;
		}
		&#about-tile {
			--icon-size: 35px;
		}
	}
	@media screen and (max-width: 1280px) {
		.tile-btn {
			display: flex;
		}
	}
</style>

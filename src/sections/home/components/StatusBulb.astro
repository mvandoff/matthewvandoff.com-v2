---
export type StatusColor = 'green' | 'yellow' | 'red';

export interface Props {
	status?: string;
	details?: string;
	color?: StatusColor;
}

const { status = 'Available', details = 'Head down building Insight @ Cyncly', color = 'green' } = Astro.props as Props;
---

<div class="status-bulb" data-status-bulb data-color={color}>
	<button
		class="status-bulb__button"
		type="button"
		aria-label={`Status: ${status}. Tap for details.`}
		aria-expanded="false"
	>
		<span class="status-bulb__dot" aria-hidden="true"></span>
	</button>
	<div class="status-bulb__tooltip" role="tooltip" hidden>
		<div class="status-bulb__tooltip-title">Status</div>
		<div class="status-bulb__tooltip-subtext">{details}</div>
	</div>
</div>

<script type="module" is:inline>
	const bulbs = document.querySelectorAll('[data-status-bulb]');

	for (const bulb of bulbs) {
		const button = bulb.querySelector('.status-bulb__button');
		const tooltip = bulb.querySelector('.status-bulb__tooltip');

		if (!(button instanceof HTMLButtonElement) || !(tooltip instanceof HTMLElement)) continue;

		let closeTimeoutId = 0;

		const sync = (isOpen) => {
			button.setAttribute('aria-expanded', String(isOpen));
		};

		const open = () => {
			window.clearTimeout(closeTimeoutId);
			if (!tooltip.hidden) return;
			tooltip.hidden = false;
			requestAnimationFrame(() => {
				bulb.dataset.open = 'true';
				sync(true);
			});
		};

		const close = () => {
			window.clearTimeout(closeTimeoutId);
			if (tooltip.hidden) return;
			delete bulb.dataset.open;
			sync(false);
			closeTimeoutId = window.setTimeout(() => {
				tooltip.hidden = true;
			}, 160);
		};

		const toggle = () => {
			if (tooltip.hidden) open();
			else close();
		};

		button.addEventListener('click', (event) => {
			event.preventDefault();
			event.stopPropagation();
			toggle();
		});

		document.addEventListener('click', (event) => {
			if (!(event.target instanceof Node)) return;
			if (!bulb.contains(event.target)) close();
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') close();
		});
	}
</script>

<style>
	.status-bulb {
		--status-dot: var(--status-success);
		--status-dot-highlight: var(--status-success-highlight);
		--status-outline: var(--status-success-outline);
		--status-tooltip-accent: var(--status-success-tooltip-accent);
		--status-text: var(--status-success-text);

		display: none;
		position: absolute;
		top: 10px;
		right: 10px;
		z-index: 999;
		isolation: isolate;
		pointer-events: auto;
	}

	.status-bulb[data-color='yellow'] {
		--status-dot: var(--status-warning);
		--status-dot-highlight: var(--status-warning-highlight);
		--status-outline: var(--status-warning-outline);
		--status-tooltip-accent: var(--status-warning-tooltip-accent);
		--status-text: var(--status-warning-text);
	}

	.status-bulb[data-color='red'] {
		--status-dot: var(--status-error);
		--status-dot-highlight: var(--status-error-highlight);
		--status-outline: var(--status-error-outline);
		--status-tooltip-accent: var(--status-error-tooltip-accent);
		--status-text: var(--status-error-text);
	}

	.status-bulb__button {
		--bulb-size: 26px;

		height: var(--bulb-size);
		width: var(--bulb-size);
		border-radius: 999px;
		padding: 0;
		border: 0;
		background: transparent;
		display: grid;
		place-items: center;
		cursor: pointer;
		appearance: none;
		touch-action: manipulation;
		position: relative;
		z-index: 2;
		transition:
			transform 120ms ease,
			box-shadow 200ms ease;
	}

	.status-bulb__button:active {
		transform: scale(0.96);
	}

	.status-bulb__button:focus-visible {
		outline: 2px solid var(--status-outline);
		outline-offset: 3px;
	}

	.status-bulb__dot {
		--dot-size: 9px;

		height: var(--dot-size);
		width: var(--dot-size);
		border-radius: 999px;
		background: radial-gradient(circle at 35% 35%, var(--status-dot-highlight), var(--status-dot));
		box-shadow:
			inset 0 0 0 1px hsl(from var(--neutral-50) h s l / 0.18),
			0 1px 0 hsl(from var(--neutral-950) h s l / 0.55);
		animation: status-bulb-breathe 2.8s ease-in-out infinite;
	}

	.status-bulb__tooltip {
		position: absolute;
		top: calc(100% + 10px);
		right: 0;
		z-index: 1;
		width: min(240px, calc(100vw - 24px));
		padding: 10px 12px;
		border-radius: 12px;
		border: 1px solid hsl(from var(--neutral-50) h s l / 0.12);
		background:
			radial-gradient(circle at 20% 0%, var(--neutral-900), hsl(from var(--neutral-950) h s l / 0)),
			linear-gradient(to bottom right, var(--neutral-900), var(--neutral-950));
		color: hsl(from var(--neutral-200) h s l / 0.92);
		box-shadow:
			0 12px 30px hsl(from var(--neutral-950) h s l / 0.55),
			inset 0 0 0 1px hsl(from var(--neutral-50) h s l / 0.04);
		transform: translateY(-6px);
		opacity: 0;
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}

	.status-bulb[data-open='true'] .status-bulb__tooltip {
		transform: translateY(0);
		opacity: 1;
	}

	.status-bulb__tooltip-title {
		font-family: 'Inter', sans-serif;
		font-size: 10px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		margin-bottom: 6px;
		color: var(--status-text, hsl(from var(--neutral-200) h s l / 0.95));
	}

	.status-bulb__tooltip-subtext {
		margin-top: 4px;
		font-family: 'Inter', sans-serif;
		font-size: 12px;
		line-height: 1.35;
		color: hsl(from var(--neutral-300) h s l / 0.92);
	}

	@keyframes status-bulb-breathe {
		0%,
		100% {
			opacity: 0.92;
			transform: translateZ(0) scale(1);
		}
		50% {
			opacity: 1;
			transform: translateZ(0) scale(1.06);
		}
	}

	@media screen and (max-width: 1280px) {
		.status-bulb {
			display: block;
		}
	}
</style>

---
// ColorTile is a component that modifies the main color values of the site

import { Icon } from 'astro-icon/components';
---

<button
	id="mb-color-tile"
	class="mb-tile mb-tile-surface"
	type="button"
	aria-expanded="false"
	aria-labelledby="mb-color-tile-label"
>
	<span class="mb-color-tile__drawer" aria-hidden="true">
		<span class="mb-color-tile__drawer-inner">
			<span class="mb-color-tile__hue-slider" data-hue-slider></span>
		</span>
	</span>
	<span class="mb-color-tile__handle">
		<Icon name="f7:paintbrush-fill" class="color-icon" aria-hidden="true" />
		<span class="mb-color-tile__dot" aria-hidden="true"></span>
		<!-- <span class="mb-social-label" id="mb-color-tile-label">Theme</span> -->
	</span>
</button>
<style>
	#mb-color-tile {
		--mb-color-tile-handle-width: calc(var(--block-size) * 5); /* Should be the same as width of the button */
		--mb-color-tile-slide-over-width: calc(var(--block-size) * 14);
		--mb-color-tile-ease: cubic-bezier(0.22, 1, 0.36, 1);
		--mb-color-tile-transition-time: 700ms;
		--mb-tile-linear-start-open: var(--main-800);
		--mb-tile-linear-end-open: hsl(from var(--main-900) h s l / 1);
		--mb-tile-radial-x: 100%;
		--mb-tile-radial-y: 100%;
		--mb-tile-linear-dir: bottom left;

		display: block;
		font-size: 31px;
		color: var(--neutral-300);
		position: relative;
		justify-self: end;
		overflow: hidden;
		isolation: isolate;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
		transition:
			width var(--mb-color-tile-transition-time) var(--mb-color-tile-ease),
			box-shadow var(--mb-color-tile-transition-time) var(--mb-color-tile-ease);
		will-change: width;
		z-index: 50 !important;

		/* Gradient border comes from layered backgrounds + background-clip on .mb-tile-surface. */
		&::after {
			content: '';
			position: absolute;
			inset: 0;
			border-radius: inherit;
			border: solid 1px transparent;
			background:
				radial-gradient(
					circle at var(--mb-tile-radial-x) var(--mb-tile-radial-y),
					var(--neutral-900),
					var(--neutral-950)
				),
				linear-gradient(
					to var(--mb-tile-linear-dir),
					var(--mb-tile-linear-start-open),
					var(--mb-tile-linear-end-open) 80%
				);
			background-origin: border-box;
			background-clip: padding-box, border-box;
			opacity: 0;
			pointer-events: none;
			transition: opacity var(--mb-color-tile-transition-time) var(--mb-color-tile-ease);
			z-index: 0;
		}
		&:focus-visible {
			outline: 2px solid hsl(from var(--neutral-200) h s l / 0.6);
			outline-offset: 2px;
		}
		&.is-open {
			width: calc(100% + var(--mb-color-tile-slide-over-width));
			box-shadow:
				0 18px 34px hsl(from var(--neutral-950) h s l / 0.32),
				0 8px 14px hsl(from var(--neutral-950) h s l / 0.22);
		}
		&.is-open::after {
			opacity: 1;
		}
	}

	.mb-color-tile__drawer {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		right: var(--mb-color-tile-handle-width);
		overflow: hidden;
		display: grid;
		place-items: center;
		opacity: 0;
		transition:
			opacity 320ms var(--mb-color-tile-ease),
			transform 520ms var(--mb-color-tile-ease);
		padding-left: 0.5rem;
		z-index: 1;
	}
	#mb-color-tile.is-open .mb-color-tile__drawer {
		opacity: 1;
	}
	.mb-color-tile__drawer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.mb-color-tile__handle {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		width: var(--mb-color-tile-handle-width);
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		z-index: 1;
		.color-icon {
			margin-top: 4px;
		}
		.mb-social-label {
			margin-top: 11px;
		}
	}
	.mb-color-tile__dot {
		position: absolute;
		width: 8px;
		height: 8px;
		background: var(--main-500);
		border-radius: 100%;
		top: 8px;
		right: 8px;
		z-index: 2;
		box-shadow: 0 0 0 2px hsl(from var(--neutral-950) h s l / 0.55);
		transition: transform var(--mb-color-tile-transition-time) var(--mb-color-tile-ease);
	}
	#mb-color-tile.is-open .mb-color-tile__dot {
		transform: scale(0.85);
	}
	@media (prefers-reduced-motion: reduce) {
		#mb-color-tile,
		.mb-color-tile__drawer,
		.mb-color-tile__handle svg,
		.mb-color-tile__dot {
			transition: none !important;
		}
	}
</style>
<script>
	import iro from '@jaames/iro';
	import {
		getBaseHue,
		prepareDynamicPalette,
		setBaseHue,
		writeStoredHue,
		MAIN_HUE_EVENT,
	} from 'scripts/global/mainHue';

	// Palette strategy: keep literal values in CSS, then rewrite them once into
	// calc(var(--main-hue-base) +/- offset) so the slider only changes one var.
	const OPEN_CLASS = 'is-open';
	const IRO_READY_ATTR = 'data-iro-ready';
	const IRO_WIDTH = 212;

	const setOpen = (tile: HTMLElement, open: boolean) => {
		tile.classList.toggle(OPEN_CLASS, open);
		tile.setAttribute('aria-expanded', open ? 'true' : 'false');

		if (open) initHueSlider(tile);
	};

	const initHueSlider = (tile: HTMLElement) => {
		// Ensure CSS vars are rewritten before the slider starts updating the base hue.
		prepareDynamicPalette();
		const sliderHost = tile.querySelector<HTMLElement>('[data-hue-slider]');
		if (!sliderHost) return;
		if (sliderHost.hasAttribute(IRO_READY_ATTR)) return;

		const tryInit = () => {
			const baseHue = getBaseHue();
			const picker = iro.ColorPicker(sliderHost, {
				width: IRO_WIDTH,
				color: { h: baseHue, s: 100, v: 100 },
				layout: [
					{
						component: iro.ui.Slider,
						options: {
							sliderType: 'hue',
							sliderSize: 25,
							borderWidth: 0,
							handleRadius: 12,
						},
					},
				],
			});

			picker.on('color:change', (color: iro.Color) => {
				// Keep updates minimal: only one CSS var changes on drag.
				setBaseHue(color.hsl.h);
				writeStoredHue(color.hsl.h);
				window.dispatchEvent(
					new CustomEvent(MAIN_HUE_EVENT, {
						detail: { hue: color.hsl.h },
					}),
				);
			});

			sliderHost.setAttribute(IRO_READY_ATTR, 'true');
		};

		requestAnimationFrame(tryInit);
	};

	document.addEventListener('DOMContentLoaded', () => {
		const tile = document.getElementById('mb-color-tile')!;

		tile.addEventListener('click', () => {
			setOpen(tile, !tile.classList.contains(OPEN_CLASS));
		});
		document.addEventListener('pointerdown', (event) => {
			if (!tile.classList.contains(OPEN_CLASS)) return;
			if (event.target instanceof Node && tile.contains(event.target)) return;
			setOpen(tile, false);
		});
	});
</script>

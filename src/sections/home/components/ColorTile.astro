---
import { Icon } from 'astro-icon/components';
---

<button
	id="mb-color-tile"
	class="mb-tile mb-tile-surface"
	type="button"
	aria-expanded="false"
	aria-label="Open accent color"
>
	<span class="mb-color-tile__drawer" aria-hidden="true">
		<span class="mb-color-tile__drawer-inner">
			<span class="mb-color-tile__hue-slider" data-hue-slider></span>
		</span>
	</span>
	<span class="mb-color-tile__handle" aria-hidden="true">
		<Icon name="f7:paintbrush-fill" />
		<span class="mb-color-tile__dot"></span>
	</span>
</button>
<script>
	import iro from '@jaames/iro';

	const OPEN_CLASS = 'is-open';
	const IRO_READY_ATTR = 'data-iro-ready';
	const IRO_WIDTH = 175;

	const getTile = () => document.getElementById('mb-color-tile');

	const setOpen = (tile: HTMLElement, open: boolean) => {
		tile.classList.toggle(OPEN_CLASS, open);
		tile.setAttribute('aria-expanded', open ? 'true' : 'false');
		tile.setAttribute('aria-label', open ? 'Close accent color' : 'Open accent color');

		if (open) initHueSlider(tile);
	};

	const initHueSlider = (tile: HTMLElement) => {
		const sliderHost = tile.querySelector<HTMLElement>('[data-hue-slider]');
		if (!sliderHost) return;
		if (sliderHost.hasAttribute(IRO_READY_ATTR)) return;

		const tryInit = () => {
			iro.ColorPicker(sliderHost, {
				width: IRO_WIDTH,
				layout: [
					{
						component: iro.ui.Slider,
						options: {
							sliderType: 'hue',
							sliderSize: 25,
							borderWidth: 0,
							handleRadius: 12,
						},
					},
				],
			});

			sliderHost.setAttribute(IRO_READY_ATTR, 'true');
		};

		requestAnimationFrame(tryInit);
	};

	document.addEventListener('DOMContentLoaded', () => {
		const tile = getTile();
		if (!tile) return;

		tile.addEventListener('click', (event) => {
			if (event.target instanceof Element && event.target.closest('[data-color-tile-slider]')) return;
			setOpen(tile, !tile.classList.contains(OPEN_CLASS));
		});
		document.addEventListener('pointerdown', (event) => {
			if (!tile.classList.contains(OPEN_CLASS)) return;
			if (event.target instanceof Node && tile.contains(event.target)) return;
			setOpen(tile, false);
		});
	});
</script>
<style>
	#mb-color-tile {
		--mb-color-tile-handle-width: calc(var(--block-size) * 5);
		--mb-color-tile-slide-over: calc(var(--block-size) * 12);
		--mb-color-tile-ease: cubic-bezier(0.22, 1, 0.36, 1);

		--mb-tile-linear-start: transparent;
		--mb-tile-linear-end: #1e1b4b64;

		display: block;
		padding: 0;
		font-size: 32px;
		color: var(--neutral-300);
		position: relative;
		justify-self: end;
		overflow: hidden;
		isolation: isolate;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
		transition:
			width 520ms var(--mb-color-tile-ease),
			box-shadow 520ms var(--mb-color-tile-ease),
			border-color 520ms var(--mb-color-tile-ease);
		will-change: width;

		&:focus-visible {
			outline: 2px solid rgba(226, 232, 240, 0.6);
			outline-offset: 2px;
		}
		&.is-open {
			width: calc(100% + var(--mb-color-tile-slide-over));
			z-index: 50;
			background-clip: border-box, border-box;
			border-color: rgba(148, 163, 184, 0.18);
			box-shadow:
				0 18px 34px rgba(0, 0, 0, 0.32),
				0 8px 14px rgba(0, 0, 0, 0.22);
		}
	}

	.mb-color-tile__drawer {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		right: var(--mb-color-tile-handle-width);
		overflow: hidden;
		display: grid;
		place-items: center;
		opacity: 0;
		transition:
			opacity 320ms var(--mb-color-tile-ease),
			transform 520ms var(--mb-color-tile-ease);
		padding-left: 0.5rem;
	}
	#mb-color-tile.is-open .mb-color-tile__drawer {
		opacity: 1;
	}
	.mb-color-tile__drawer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.mb-color-tile__handle {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		width: var(--mb-color-tile-handle-width);
		display: grid;
		place-items: center;
	}
	.mb-color-tile__dot {
		position: absolute;
		width: 8px;
		height: 8px;
		background: var(--main-500);
		border-radius: 100%;
		top: 8px;
		right: 8px;
		z-index: 2;
		box-shadow: 0 0 0 2px rgba(2, 6, 23, 0.55);
		transition: transform 1000ms var(--mb-color-tile-ease);
	}
	#mb-color-tile.is-open .mb-color-tile__dot {
		transform: scale(0.85);
	}
	@media (prefers-reduced-motion: reduce) {
		#mb-color-tile,
		.mb-color-tile__drawer,
		.mb-color-tile__handle svg,
		.mb-color-tile__dot {
			transition: none !important;
		}
	}
</style>

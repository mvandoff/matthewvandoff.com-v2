---
// ColorTile is a component that modifies the main color values of the site

import { Icon } from 'astro-icon/components';
---

<button
	id="mb-color-tile"
	class="mb-tile mb-tile-surface"
	type="button"
	aria-expanded="false"
	aria-label="Open accent color"
>
	<span class="mb-color-tile__drawer" aria-hidden="true">
		<span class="mb-color-tile__drawer-inner">
			<span class="mb-color-tile__hue-slider" data-hue-slider></span>
		</span>
	</span>
	<span class="mb-color-tile__handle" aria-hidden="true">
		<Icon name="f7:paintbrush-fill" />
		<span class="mb-color-tile__dot"></span>
	</span>
</button>
<script>
	import iro from '@jaames/iro';

	// Palette strategy: keep literal values in CSS, then rewrite them once into
	// calc(var(--main-hue-base) +/- offset) so the slider only changes one var.
	const OPEN_CLASS = 'is-open';
	const IRO_READY_ATTR = 'data-iro-ready';
	const IRO_WIDTH = 175;
	const MAIN_HUE_VAR = '--main-hue-base';
	const MAIN_COLOR_PREFIX = '--main-';
	const MAIN_COLOR_KEYS = ['50', '100', '200', '300', '400', '500', '600', '700', '800', '900', '950', '1k'] as const;
	const MAIN_COLOR_BASE_KEY = '50';
	const DEFAULT_MAIN_HUE = 226;
	const MAIN_HUE_EVENT = 'mb-main-hue-change';

	// Parse any HSL-ish string into numeric H/S/L/A using iro's parser.
	const parseHsl = (value: string) => {
		if (!value) return null;
		try {
			return new iro.Color(value).hsl;
		} catch {
			return null;
		}
	};

	const getTile = () => document.getElementById('mb-color-tile');
	// Prefer the computed base hue var, else fall back to the current CSS palette.
	const getBaseHue = () => {
		const styles = getComputedStyle(document.documentElement);
		const rawHue = styles.getPropertyValue(MAIN_HUE_VAR).trim();
		const parsedHue = Number.parseFloat(rawHue);
		if (Number.isFinite(parsedHue)) return parsedHue;

		const rawBase = styles.getPropertyValue(`${MAIN_COLOR_PREFIX}${MAIN_COLOR_BASE_KEY}`).trim();
		const baseColor = parseHsl(rawBase);
		return baseColor ? baseColor.h : DEFAULT_MAIN_HUE;
	};
	// Set only the base hue; CSS expressions handle the rest.
	const setBaseHue = (hue: number) => {
		document.documentElement.style.setProperty(MAIN_HUE_VAR, `${Math.round(hue)}`);
	};

	// Guard to avoid recomputing offsets on every open.
	let paletteReady = false;

	// Trim extra trailing zeros so we don't bloat inline CSS.
	const formatNumber = (value: number, decimals = 2) => {
		const rounded = value.toFixed(decimals);
		return rounded.replace(/\.?0+$/, '');
	};

	// Build "calc(var(--main-hue-base) +/- offset)" for each palette entry.
	const formatHueExpression = (offset: number) => {
		if (!Number.isFinite(offset)) return `var(${MAIN_HUE_VAR})`;
		if (offset === 0) return `var(${MAIN_HUE_VAR})`;
		const operator = offset < 0 ? '-' : '+';
		const magnitude = formatNumber(Math.abs(offset), 2);
		return `calc(var(${MAIN_HUE_VAR}) ${operator} ${magnitude})`;
	};

	// Serialize an HSL string while preserving alpha when present.
	const formatHsl = (hueExpression: string, saturation: number, lightness: number, alpha?: number) => {
		const saturationValue = formatNumber(saturation, 2);
		const lightnessValue = formatNumber(lightness, 2);
		if (Number.isFinite(alpha)) {
			const alphaValue = formatNumber(alpha ?? 1, 3);
			return `hsl(${hueExpression} ${saturationValue}% ${lightnessValue}% / ${alphaValue})`;
		}
		return `hsl(${hueExpression} ${saturationValue}% ${lightnessValue}%)`;
	};

	// Read literal palette values, compute offsets from the base hue, and rewrite
	// each --main-* to use calc(var(--main-hue-base) +/- offset) while preserving S/L/A.
	const prepareDynamicPalette = () => {
		if (paletteReady) return;
		const root = document.documentElement;
		const styles = getComputedStyle(root);
		// Snapshot current CSS values so designers can tweak in styles.css.
		const palette = MAIN_COLOR_KEYS.map((key) => {
			const raw = styles.getPropertyValue(`${MAIN_COLOR_PREFIX}${key}`).trim();
			return { key, hsl: parseHsl(raw) };
		});
		const baseEntry = palette.find((entry) => entry.key === MAIN_COLOR_BASE_KEY);
		if (!baseEntry?.hsl || !Number.isFinite(baseEntry.hsl.h)) return;

		const baseHue = baseEntry.hsl.h;
		// Seed the runtime base hue from the palette's base color.
		root.style.setProperty(MAIN_HUE_VAR, `${Math.round(baseHue)}`);

		// Rewrite each --main-* into a calc() expression that references the base hue.
		palette.forEach((entry) => {
			if (!entry.hsl) return;
			const { h, s, l, a } = entry.hsl;
			if (!Number.isFinite(h) || !Number.isFinite(s) || !Number.isFinite(l)) return;
			const hueExpression = formatHueExpression(h - baseHue);
			root.style.setProperty(`${MAIN_COLOR_PREFIX}${entry.key}`, formatHsl(hueExpression, s, l, a));
		});

		paletteReady = true;
	};

	const setOpen = (tile: HTMLElement, open: boolean) => {
		tile.classList.toggle(OPEN_CLASS, open);
		tile.setAttribute('aria-expanded', open ? 'true' : 'false');
		tile.setAttribute('aria-label', open ? 'Close accent color' : 'Open accent color');

		if (open) initHueSlider(tile);
	};

	const initHueSlider = (tile: HTMLElement) => {
		// Ensure CSS vars are rewritten before the slider starts updating the base hue.
		prepareDynamicPalette();
		const sliderHost = tile.querySelector<HTMLElement>('[data-hue-slider]');
		if (!sliderHost) return;
		if (sliderHost.hasAttribute(IRO_READY_ATTR)) return;

		const tryInit = () => {
			const baseHue = getBaseHue();
			const picker = iro.ColorPicker(sliderHost, {
				width: IRO_WIDTH,
				color: { h: baseHue, s: 100, v: 100 },
				layout: [
					{
						component: iro.ui.Slider,
						options: {
							sliderType: 'hue',
							sliderSize: 25,
							borderWidth: 0,
							handleRadius: 12,
						},
					},
				],
			});

			picker.on('color:change', (color: iro.Color) => {
				// Keep updates minimal: only one CSS var changes on drag.
				setBaseHue(color.hsl.h);
				window.dispatchEvent(
					new CustomEvent(MAIN_HUE_EVENT, {
						detail: { hue: color.hsl.h },
					})
				);
			});

			sliderHost.setAttribute(IRO_READY_ATTR, 'true');
		};

		requestAnimationFrame(tryInit);
	};

	document.addEventListener('DOMContentLoaded', () => {
		const tile = getTile();
		if (!tile) return;

		tile.addEventListener('click', (event) => {
			if (event.target instanceof Element && event.target.closest('[data-hue-slider]')) return;
			setOpen(tile, !tile.classList.contains(OPEN_CLASS));
		});
		document.addEventListener('pointerdown', (event) => {
			if (!tile.classList.contains(OPEN_CLASS)) return;
			if (event.target instanceof Node && tile.contains(event.target)) return;
			setOpen(tile, false);
		});
	});
</script>
<style>
	#mb-color-tile {
		--mb-color-tile-handle-width: calc(var(--block-size) * 5);
		--mb-color-tile-slide-over: calc(var(--block-size) * 12);
		--mb-color-tile-ease: cubic-bezier(0.22, 1, 0.36, 1);

		--mb-tile-linear-start: transparent;
		--mb-tile-linear-end: #1e1b4b64;

		display: block;
		padding: 0;
		font-size: 32px;
		color: var(--neutral-300);
		position: relative;
		justify-self: end;
		overflow: hidden;
		isolation: isolate;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
		transition:
			width 520ms var(--mb-color-tile-ease),
			box-shadow 520ms var(--mb-color-tile-ease),
			border-color 520ms var(--mb-color-tile-ease);
		will-change: width;

		&:focus-visible {
			outline: 2px solid rgba(226, 232, 240, 0.6);
			outline-offset: 2px;
		}
		&.is-open {
			width: calc(100% + var(--mb-color-tile-slide-over));
			z-index: 50;
			background-clip: border-box, border-box;
			border-color: rgba(148, 163, 184, 0.18);
			box-shadow:
				0 18px 34px rgba(0, 0, 0, 0.32),
				0 8px 14px rgba(0, 0, 0, 0.22);
		}
	}

	.mb-color-tile__drawer {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		right: var(--mb-color-tile-handle-width);
		overflow: hidden;
		display: grid;
		place-items: center;
		opacity: 0;
		transition:
			opacity 320ms var(--mb-color-tile-ease),
			transform 520ms var(--mb-color-tile-ease);
		padding-left: 0.5rem;
	}
	#mb-color-tile.is-open .mb-color-tile__drawer {
		opacity: 1;
	}
	.mb-color-tile__drawer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.mb-color-tile__handle {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		width: var(--mb-color-tile-handle-width);
		display: grid;
		place-items: center;
	}
	.mb-color-tile__dot {
		position: absolute;
		width: 8px;
		height: 8px;
		background: var(--main-500);
		border-radius: 100%;
		top: 8px;
		right: 8px;
		z-index: 2;
		box-shadow: 0 0 0 2px rgba(2, 6, 23, 0.55);
		transition: transform 1000ms var(--mb-color-tile-ease);
	}
	#mb-color-tile.is-open .mb-color-tile__dot {
		transform: scale(0.85);
	}
	@media (prefers-reduced-motion: reduce) {
		#mb-color-tile,
		.mb-color-tile__drawer,
		.mb-color-tile__handle svg,
		.mb-color-tile__dot {
			transition: none !important;
		}
	}
</style>

---
import { Icon } from 'astro-icon/components';

type Props = {
	href: string;
	icon: string;
	label: string;
	brand: 'li' | 'gh';
	iconId?: string;
};

const { href, icon, label, brand, iconId } = Astro.props as Props;
---

<a class="mb-social-link" data-brand={brand} href={href} aria-label={label}>
	<span class="mb-social-brand-icon" aria-hidden="true">
		<Icon name={icon} id={iconId} />
	</span>
	<span class="mb-social-label">{label}</span>
</a>

<style>
	.mb-social-link {
		--mb-social-radial-x: 0%;
		--mb-social-radial-y: 0%;
		--mb-social-icon-size: 48px;
		--mb-social-border: rgba(255, 255, 255, 0.12);
		--mb-social-border-dim: rgba(255, 255, 255, 0.06);
		--mb-social-edge-dim: rgba(255, 255, 255, 0.035);

		display: none;
		height: 100%;
		width: 100%;
		border-radius: var(--home-border-radius);
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		padding: 0.5rem;
		position: relative;
		background-color: transparent;

		&::before {
			content: '';
			position: absolute;
			border-radius: var(--home-border-radius);
			inset: 0;
			background:
				linear-gradient(var(--mb-social-border), var(--mb-social-border)) top / 100% 1px no-repeat,
				linear-gradient(var(--mb-social-border-dim), var(--mb-social-border-dim)) bottom / 100% 1px no-repeat,
				linear-gradient(to bottom, var(--mb-social-border), var(--mb-social-edge-dim) 55%) left / 1px 100% no-repeat,
				linear-gradient(to bottom, var(--mb-social-border), var(--mb-social-edge-dim) 55%) right / 1px 100% no-repeat,
				linear-gradient(0deg, rgba(255, 255, 255, 0.035), transparent 62%),
				radial-gradient(
					120% 120% at var(--mb-social-radial-x) var(--mb-social-radial-y),
					rgba(255, 255, 255, 0.08),
					transparent 55%
				),
				linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 62%);
			pointer-events: none;
		}
		.mb-social-label {
			font-family: 'Inter', sans-serif;
			font-size: 10px;
			letter-spacing: 0.15em;
			color: var(--neutral-400);
		}
		svg {
			height: var(--mb-social-icon-size);
			width: var(--mb-social-icon-size);
			color: var(--neutral-300);
		}
		&[data-brand='li'] {
			--mb-social-radial-x: 100%;
		}
	}
	@media screen and (max-width: 1280px) {
		.mb-social-link {
			display: flex;
		}
	}
</style>

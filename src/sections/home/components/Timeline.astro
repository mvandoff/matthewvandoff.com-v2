---
import TimelineBlock from 'sections/home/components/TimelineBlock.astro';
---

<div class="timeline">
	<div class="exp-container">
		<h3>experience</h3>
	</div>
	<div class="tl-blocks">
		<TimelineBlock
			company="Cyncly"
			title="Web Developer"
			start="2024"
			end="present"
			description="Worked on the frontend team for Insight, a full scale ERP solution for manufacturers, migrating a monolithic legacy application to a modern React web app as well as developing new cutting-edge features."
			link="https://www.cyncly.com/"
		/>
		<TimelineBlock
			company="Game Builds"
			icon="🪦"
			title="Full Stack Developer"
			start="2023"
			end="2024"
			description="Helped build, launch, and maintain diablobuilds.com which was an online resource and community for the popular online video game Diablo IV, featuring an advanced character builder with in depth analytics and customization."
			link="https://www.instagram.com/diablobuilds"
		/>
		<TimelineBlock
			company="Applied Visions"
			title="Software Engineer"
			start="2021"
			end="2023"
			description="Developed two key enterprise applications: a professional networking platform for the insurance industry and an AI-powered project management tool for government clients, as well as mentoring junior developers for the client."
			link="https://avi.com"
		/>
	</div>
</div>

<style>
	.timeline {
		--timeline-line-lit: 0px;
		--timeline-line-width: 4px;
		--timeline-line-active: var(--main-300);
		--timeline-line-mini-block-size: calc(var(--block-size) / 2);
		--timeline-line-seam-color: color-mix(in srgb, var(--timeline-line-active) 55%, transparent);
		width: 100%;
		display: flex;
		flex-direction: column;
	}
	.exp-container {
		height: var(--block-size);
		display: flex;
		align-items: center;
		width: 100%;
		color: var(--slate-200);
		margin: 0;
		font-size: 22px;
	}
	.tl-blocks {
		display: flex;
		flex-direction: column;
		position: relative;

		&::after {
			content: '';
			position: absolute;
			left: -5px;
			width: var(--timeline-line-width);
			pointer-events: none;
			bottom: 2px;
			height: var(--timeline-line-lit);
			background: repeating-linear-gradient(
				to top,
				var(--timeline-line-active) 0,
				var(--timeline-line-active) calc(var(--timeline-line-mini-block-size) - 1px),
				var(--timeline-line-seam-color) calc(var(--timeline-line-mini-block-size) - 1px),
				var(--timeline-line-seam-color) var(--timeline-line-mini-block-size)
			);
			box-shadow: 0 0 12px color-mix(in srgb, var(--timeline-line-active) 70%, transparent);
			transition: height 320ms ease-in-out;
			/* Keep the lit connector above timeline-card overlay effects. */
			z-index: 140;
		}
	}
	@media screen and (max-width: 1280px) {
		.timeline {
			display: none;
		}
	}
</style>

---
import { Icon } from 'astro-icon/components';

type Props = {
	href: string;
	icon: string;
	label: string;
	brand?: 'linkedin' | 'github';
	target?: '_blank' | '_self' | '_parent' | '_top';
	rel?: string;
};

const { href, icon, label, brand: brandProp, target = '_blank', rel = 'noreferrer' } = Astro.props as Props;

let brand: 'linkedin' | 'github' | undefined = brandProp;
try {
	if (!brand) {
		const hostname = new URL(href).hostname.toLowerCase();
		if (hostname.includes('linkedin')) brand = 'linkedin';
		if (hostname.includes('github')) brand = 'github';
	}
} catch {
	// Ignore invalid/relative URLs.
}

if (!brand) {
	const token = `${icon} ${label}`.toLowerCase();
	if (token.includes('linkedin')) brand = 'linkedin';
	if (token.includes('github')) brand = 'github';
}
---

<a
	class="social-link"
	href={href}
	target={target}
	rel={rel}
	aria-label={label}
	data-block-trail="ignore"
	data-brand={brand}
>
	<div class="social-wave-grid" aria-hidden="true"></div>
	<div class="social-trail-grid" aria-hidden="true"></div>
	<div class="social-link-icon-container">
		<Icon name={icon} />
	</div>
	<div class="social-link-text-container">
		<span class="social-label">{label}</span>
	</div>
</a>

<style>
	.social-link {
		/* border: 1px solid var(--bg-block-grid-line-color); */
		--social-hover-color: var(--main-200);
		--social-focus-outline-color: var(--main-400);
		--social-hover-bg-color: hsl(from var(--neutral-50) h s l / 0.02);
		--social-wave-color: var(--main-950);
		--social-wave-border-color: hsla(45, 100%, 50%, 0.06);
		--social-trail-color: var(--bg-block-color);

		width: calc(3 * var(--block-size));
		height: var(--block-size);
		border-radius: 2px;
		display: flex;
		align-items: center;
		color: var(--neutral-400);
		background-color: hsl(from var(--neutral-50) h s l / 0.02);
		border: 1px solid hsl(from var(--neutral-50) h s l / 0.08);
		position: relative;
		overflow: hidden;
		isolation: isolate;
		transition:
			color 0.25s ease,
			background-color 0.25s ease,
			box-shadow 0.25s ease;

		&.is-distorting {
			will-change: filter;
		}
		&:hover {
			color: var(--social-hover-color);
			background-color: var(--social-hover-bg-color);
			border-color: var(--social-wave-border-color);
			box-shadow: inset 0 0 0 1px var(--social-wave-border-color);
		}
		&:focus-visible {
			outline: 2px solid var(--social-focus-outline-color);
			outline-offset: 2px;
			color: var(--social-hover-color);
			background-color: var(--social-hover-bg-color);
			border-color: var(--social-wave-border-color);
			box-shadow: inset 0 0 0 1px var(--social-wave-border-color);
		}
		&[data-brand='linkedin'] {
			--social-hover-color: #c0dbf7;
			--social-focus-outline-color: #0a66c2;
			--social-hover-bg-color: rgba(10, 102, 194, 0.08);
			--social-wave-color: rgba(10, 102, 194, 0.22);
			--social-wave-border-color: rgba(10, 102, 194, 0.109);
			--social-trail-color: rgba(10, 102, 194, 0.5);
		}

		&[data-brand='github'] {
			--social-hover-color: #b9dec0;
			--social-focus-outline-color: #2ea043;
			--social-hover-bg-color: rgba(46, 160, 67, 0.06);
			--social-wave-color: rgba(46, 160, 67, 0.18);
			--social-wave-border-color: rgba(46, 160, 67, 0.071);
			--social-trail-color: rgba(46, 160, 67, 0.45);
		}
	}

	.social-wave-grid {
		--social-wave-fade-in: var(--bg-block-wave-fade-in, 250ms);
		--social-wave-fade-out: var(--bg-block-wave-fade-out, 400ms);
		--social-wave-border-width: 1px;
		--social-wave-border-perimeter-width: 2px;

		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		display: grid;
		justify-content: center;
		align-content: center;
	}

	.social-trail-grid {
		--social-trail-fade-in: var(--bg-block-fade-in);
		--social-trail-fade-out: var(--bg-block-fade-out);
		--social-trail-hold: var(--bg-block-hold);
		--social-trail-radius: 9px;

		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		display: grid;
		justify-content: center;
		align-content: center;
	}

	.social-trail-grid :global(.social-trail-block) {
		position: relative;
	}

	.social-trail-grid :global(.social-trail-block)::after {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0;
		background-color: var(--social-trail-color);
		transition: opacity var(--social-trail-fade-out) ease-out;
	}

	.social-trail-grid :global(.social-trail-block.is-lit)::after {
		opacity: 1;
		transition-duration: var(--social-trail-fade-in);
	}

	.social-wave-block {
		/* NOTE: blocks are created dynamically in JS (no Astro scope attr),
		   so their selectors must be global to style them. */
	}

	.social-wave-grid :global(.social-wave-block) {
		position: relative;
		--social-wave-border-top-width: var(--social-wave-border-width);
		--social-wave-border-right-width: var(--social-wave-border-width);
		--social-wave-border-bottom-width: var(--social-wave-border-width);
		--social-wave-border-left-width: var(--social-wave-border-width);
	}

	.social-wave-grid :global(.social-wave-block.is-edge-top) {
		--social-wave-border-top-width: var(--social-wave-border-perimeter-width);
	}
	.social-wave-grid :global(.social-wave-block.is-edge-right) {
		--social-wave-border-right-width: var(--social-wave-border-perimeter-width);
	}
	.social-wave-grid :global(.social-wave-block.is-edge-bottom) {
		--social-wave-border-bottom-width: var(--social-wave-border-perimeter-width);
	}
	.social-wave-grid :global(.social-wave-block.is-edge-left) {
		--social-wave-border-left-width: var(--social-wave-border-perimeter-width);
	}

	.social-wave-grid :global(.social-wave-block)::before {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0;
		background-color: var(--social-wave-color);
		box-sizing: border-box;
		border-style: solid;
		border-color: var(--social-wave-border-color);
		border-width: var(--social-wave-border-top-width) var(--social-wave-border-right-width)
			var(--social-wave-border-bottom-width) var(--social-wave-border-left-width);
		transition: opacity var(--social-wave-fade-out) ease-out;
	}

	.social-wave-grid :global(.social-wave-block.is-lit)::before {
		opacity: 1;
		transition-duration: var(--social-wave-fade-in);
	}
	.social-link-icon-container {
		height: 100%;
		flex-basis: var(--block-size);
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
		z-index: 2;

		svg {
			height: 3rem;
			width: 3rem;
			color: currentColor;
			transition: color 0.25s ease;
			flex-shrink: 0;
		}
	}
	.social-link-text-container {
		display: flex;
		align-items: center;
		padding-left: 0.5rem;
		font-family: 'Inter', sans-serif;
		font-size: 16px;
		letter-spacing: 0.15rem;
		/* font-weight: 600; */
		position: relative;
		z-index: 2;
	}

	@media screen and (max-width: 1280px) {
		.social-link {
			width: 100%;
			height: auto;
			min-height: 56px;
			border-radius: 2px;
			background-color: hsl(from var(--neutral-50) h s l / 0.02);
			border: 1px solid hsl(from var(--neutral-50) h s l / 0.1);
		}
		.social-trail-grid {
			--social-trail-radius: 2px;
		}
		.social-link-icon-container {
			flex-basis: 56px;
		}
		.social-link-icon-container svg {
			height: 2.25rem;
			width: 2.25rem;
		}
		.social-link-text-container {
			padding-left: 0;
			font-size: 14px;
			letter-spacing: 0.12rem;
		}
	}

	@media screen and (max-width: 767px) {
		.social-link {
			min-height: 60px;
		}
	}
</style>

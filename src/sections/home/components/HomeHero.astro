---
import 'sections/home/styles/desktop/home-hero.css';
import 'sections/home/styles/mobile/mb-home-hero.css';
import 'sections/home/styles/mobile/mb-home-hero-grid.css';
import HomeImage from 'sections/home/components/HomeImage.astro';
import ColorTile from 'sections/home/components/ColorTile.astro';
import JoyStickTile from 'sections/home/components/JoyStickTile.astro';
import StatusBulb from 'sections/home/components/StatusBulb.astro';
import Liquid from 'sections/home/components/Liquid.astro';
import Button from 'sections/home/components/Button.astro';
---

<div class="screen-hero screen" data-mobile-nav-label="welcome">
	<Liquid />

	<div id="mb-side-rail" class="mb-tile liquid"></div>
	<div class="mb-hero-image-layer left-grid">
		<div class="left-image">
			<HomeImage />
		</div>
	</div>
	<div class="left left-grid intro-container liquid" data-liquid-opacity="0.4">
		<StatusBulb />
		<div class="left-intro">
			<h1>
				matthew<br class="name-break" />
				<span class="last-name">van&nbsp;doff</span>
			</h1>
			<h2>software developer</h2>
			<p id="headline">Building the internet one line at a time</p>
		</div>
	</div>

	<div class="mb-hero-tile-group">
		<Button
			href="https://www.linkedin.com/in/matthew-vandoff/"
			icon="fa7-brands:linkedin"
			label="LinkedIn"
			focusCorner="se"
			type="external"
			id="li-btn"
			className="liquid"
		/>
		<Button
			href="https://github.com/mvandoff"
			icon="fa7-brands:github"
			label="GitHub"
			id="gh-btn"
			type="external"
			focusCorner="sw"
			className="liquid"
		/>
		<ColorTile />
		<Button
			href="/work"
			id="work-btn"
			label="Work"
			icon="lucide:code-xml"
			type="internal"
			focusCorner="ne"
			className="liquid"
		/>
		<Button id="about-tile" label="About" icon="ci:info-square" type="scroll" focusCorner="nw" className="liquid" />
		<JoyStickTile />
	</div>
</div>

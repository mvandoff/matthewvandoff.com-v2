---
import Projects from 'sections/work/Projects.astro';
---

<div id="project-overlay-container">
	<div id="project-overlay">
		<div data-overlay="text-target" class="overlay-title-wrap"></div>
		<div data-overlay="img-target" class="overlay-img-wrap"></div>

		<Projects />
	</div>
</div>

<style is:global>
	.overlay-closed {
		#project-overlay {
			pointer-events: none;
			opacity: 0;
		}
		.overlay-img-wrap::after {
			opacity: 0;
		}
	}
	#project-overlay-container {
		width: 100%;
		z-index: 2;
		inset: 0;
		height: auto;
		position: fixed;
		overflow: auto;
		margin-top: 5rem;
	}

	#project-overlay {
		/* background:
			radial-gradient(1200px 600px at 100% 100%, rgba(255, 143, 201, 0.12), transparent 60%),
			linear-gradient(180deg, rgba(16, 10, 19, 0.96), rgba(6, 6, 8, 0.98)); */
		#proj-btsm-header {
			color: var(--btsm-bg-700);
		}
	}
	.overlay-title-wrap {
		text-align: center;
		flex-flow: column;
		justify-content: center;
		align-items: center;
		width: 100%;
		height: 8em;
		display: flex;
		position: relative;
	}
	.overlay-img-wrap {
		position: relative;
		display: flex;
		justify-content: center;
		img {
			margin-top: 4rem;
		}
	}
	html:not([active-proj='btsm']) {
		.overlay-img-wrap::after {
			content: '';
			position: absolute;
			inset: 0;
			opacity: 1;
			background: linear-gradient(transparent, black);
			transition: all var(--overlay-transition-time);
		}
	}
	.overlay-nav {
		z-index: 999;
		pointer-events: auto;
		justify-content: space-between;
		align-items: flex-end;
		display: none;
		position: absolute;
		inset: auto 0% 0%;
		overflow: hidden;
		color: white;

		button:hover {
			color: var(--main-200);
		}
	}
	#project-overlay {
		@media screen and (min-width: 1024px) {
			padding: 2rem 2rem;
		}
		@media screen and (max-width: 1023px) {
			padding: 1rem 0.5rem;
		}
		@media screen and (max-width: 767px) {
			.overlay-title-wrap {
				height: 4rem;
			}
		}
	}
</style>

---
import Overlay from 'sections/work/Overlay.astro';
import ProjectList from 'sections/work/ProjectList.astro';
import ProjectImageList from 'sections/work/ProjectImageList.astro';
---

<section class="overlay-closed" id="work">
	<div class="main">
		<!-- <p id="work-intro">
			Below is some of the work I have completed outside of my full time employment. Select a project to learn more
			about it.
		</p> -->
		<div class="main-col img-col">
			<ProjectImageList />
		</div>
		<div class="main-col proj-col">
			<ProjectList />
		</div>
	</div>

	<Overlay />
</section>

<style>
	#work {
		transition: background 1s ease;
		position: relative;
	}
	.overlay-open {
		.main {
			pointer-events: none;
		}
	}
	.main {
		width: 100%;
		height: 100%;
		box-sizing: border-box;
		padding: 6rem 2rem;
		position: relative;
		display: flex;
	}
	.main-col {
		width: 50%;
		height: 100%;
	}
	.proj-col {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		z-index: 99;
	}
	#work-intro {
		position: absolute;
		right: 4rem;
		padding-top: 6rem;
		text-align: right;
		margin-left: auto;
	}
</style>
<style is:global>
	#work {
		@media screen and (min-width: 1024px) {
			#work-intro {
				font-size: 20px;
				width: 475px;
			}
		}
		@media screen and (max-width: 1023px) {
			.main {
				padding: 2rem 0rem;
				flex-direction: column;
			}
			.main-col {
				display: flex;
				justify-content: center;
				align-items: center;
				width: 100%;
			}
			.img-col {
				display: none;
			}
		}
		@media screen and (max-width: 767px) {
			#work-intro {
				display: none;
			}
			.main-img-list {
				margin: 0 auto;
			}
			.img-col {
				padding-top: 3rem;
				width: 100%;
			}
		}
	}
</style>

<script>
	import { gsap } from 'gsap';
	import { CustomEase } from 'gsap/CustomEase';
	import { Flip } from 'gsap/Flip';
	import { initWorkPage } from 'sections/work/scripts/work/initWorkPage';

	document.addEventListener('DOMContentLoaded', () => {
		gsap.registerPlugin(CustomEase, Flip);
		CustomEase.create('osmo-ease', '0.625, 0.05, 0, 1');

		gsap.defaults({
			ease: 'osmo-ease',
			duration: 0.725,
		});

		initWorkPage();

		// Dev helpers: open overlay on load via ?open=syfr|btsm|mvdc and expose a global trigger
		try {
			const params = new URLSearchParams(location.search);
			const openId = params.get('open'); // syfr | btsm | mvdc
			if (openId) {
				const li = document.querySelector(`.proj-list-item[data-proj-id="${openId}"]`);
				if (li)
					li.dispatchEvent(new PointerEvent('pointerdown', { bubbles: true, pointerType: 'mouse', isPrimary: true }));
			}
		} catch (e) {
			// no-op: helper only for local dev
		}
	});
</script>

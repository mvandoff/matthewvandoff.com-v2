---
interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;
---

<div class={`proj-brands-grid${className ? ` ${className}` : ''}`}>
	<slot />
</div>

<style is:global>
	.proj-brands-grid {
		--proj-brands-radius: var(--radius-none);
		--proj-brands-tile-radius: var(--radius-none);
		--proj-brands-radial-x: 100%;
		--proj-brands-radial-y: 100%;
		--proj-brands-linear-dir: bottom right;
		--proj-brands-border-a: hsl(from var(--neutral-200) h s l / 0.08);
		--proj-brands-border-b: hsl(from var(--neutral-200) h s l / 0.01);
		--proj-brands-fill-a: hsl(from var(--neutral-950) h s l / 0.72);
		--proj-brands-fill-b: hsl(from var(--neutral-950) h s l / 0.94);
		--proj-brands-scanline-alpha: 0.02;

		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 0.75rem;
		width: min(760px, 100%);
		margin: 1.15rem auto 0;
		padding: 1rem 1rem;
		border-radius: var(--proj-brands-radius);

		border: 1px solid transparent;
		background:
			repeating-linear-gradient(
				0deg,
				hsl(from var(--neutral-200) h s l / var(--proj-brands-scanline-alpha)) 0px 1px,
				transparent 1px 4px
			),
			radial-gradient(
				circle at var(--proj-brands-radial-x) var(--proj-brands-radial-y),
				hsl(from var(--neutral-200) h s l / 0.035),
				transparent 55%
			),
			linear-gradient(180deg, var(--proj-brands-fill-a), var(--proj-brands-fill-b)),
			linear-gradient(135deg, var(--proj-brands-border-a), var(--proj-brands-border-b));
		background-origin: border-box;
		background-clip: padding-box, padding-box, border-box;
		backdrop-filter: blur(8px);
		box-shadow:
			0 10px 22px rgb(0 0 0 / 0.2),
			inset 0 0 0 1px rgb(0 0 0 / 0.22);
	}

	.proj-brands-grid .brand {
		--proj-brand-border-a: hsl(from var(--neutral-200) h s l / 0.08);
		--proj-brand-border-b: hsl(from var(--neutral-200) h s l / 0.015);
		--proj-brand-fill-a: hsl(from var(--neutral-950) h s l / 0.62);
		--proj-brand-fill-b: hsl(from var(--neutral-950) h s l / 0.86);
		--proj-brand-outline: hsl(from var(--neutral-200) h s l / 0.05);

		display: flex;
		align-items: center;
		gap: 1rem;
		width: 100%;
		min-height: 74px;
		padding: 0.9rem 1.05rem;
		border-radius: var(--proj-brands-tile-radius);

		border: 1px solid transparent;
		background:
			linear-gradient(180deg, var(--proj-brand-fill-a), var(--proj-brand-fill-b)),
			linear-gradient(135deg, var(--proj-brand-border-a), var(--proj-brand-border-b));
		background-origin: border-box;
		background-clip: padding-box, border-box;
		box-shadow:
			0 8px 14px rgb(0 0 0 / 0.16),
			inset 0 0 0 1px var(--proj-brand-outline);

		transition:
			box-shadow 160ms ease,
			background 160ms ease;
	}

	@media (hover: hover) and (pointer: fine) {
		.proj-brands-grid .brand:hover {
			--proj-brand-border-a: hsl(from var(--neutral-200) h s l / 0.16);
			--proj-brand-border-b: hsl(from var(--neutral-200) h s l / 0.04);
			--proj-brand-outline: hsl(from var(--neutral-200) h s l / 0.12);
		}
	}

	.proj-brands-grid .brand svg {
		width: 2.6rem;
		height: 2.6rem;
		flex: none;
	}

	.proj-brands-grid .brand-name {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.08em;
		white-space: normal;
		line-height: 1.1;
	}

	@media (prefers-reduced-motion: reduce) {
		.proj-brands-grid .brand {
			transition: none;
		}

		@media (hover: hover) and (pointer: fine) {
			.proj-brands-grid .brand:hover {
				transform: none;
				box-shadow: none;
			}
		}
	}

	@media screen and (max-width: 767px) {
		.proj-brands-grid {
			grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
			gap: 0.7rem;
			padding: 0.75rem 0.75rem;
		}

		.proj-brands-grid .brand {
			min-height: 68px;
			gap: 0.75rem;
			padding: 0.75rem;
		}

		.proj-brands-grid .brand svg {
			width: 2rem;
			height: 2.2rem;
		}
	}

	/* By The Sea uses a light page background, so invert the panel language there. */
	html[active-proj='btsm'] .proj-brands-grid {
		--proj-brands-radial-x: 0%;
		--proj-brands-radial-y: 0%;
		--proj-brands-border-a: hsl(from var(--neutral-950) h s l / 0.12);
		--proj-brands-border-b: hsl(from var(--neutral-950) h s l / 0.03);
		--proj-brands-fill-a: hsl(from var(--neutral-50) h s l / 0.92);
		--proj-brands-fill-b: hsl(from var(--neutral-100) h s l / 0.98);
		--proj-brands-scanline-alpha: 0.035;

		box-shadow:
			0 12px 24px rgb(0 0 0 / 0.08),
			inset 0 0 0 1px hsl(from var(--neutral-950) h s l / 0.05);
	}

	html[active-proj='btsm'] .proj-brands-grid .brand {
		--proj-brand-border-a: hsl(from var(--neutral-950) h s l / 0.12);
		--proj-brand-border-b: hsl(from var(--neutral-950) h s l / 0.04);
		--proj-brand-fill-a: hsl(from var(--neutral-50) h s l / 0.92);
		--proj-brand-fill-b: hsl(from var(--neutral-100) h s l / 0.98);
		--proj-brand-outline: hsl(from var(--neutral-950) h s l / 0.06);

		box-shadow:
			0 10px 18px rgb(0 0 0 / 0.08),
			inset 0 0 0 1px var(--proj-brand-outline);
	}

	@media (hover: hover) and (pointer: fine) {
		html[active-proj='btsm'] .proj-brands-grid .brand:hover {
			--proj-brand-border-a: hsl(from var(--neutral-950) h s l / 0.18);
			--proj-brand-border-b: hsl(from var(--neutral-950) h s l / 0.06);
			--proj-brand-outline: hsl(from var(--neutral-950) h s l / 0.12);
		}
	}
</style>

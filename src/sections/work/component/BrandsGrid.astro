---
interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;
---

<div class={`proj-brands-grid${className ? ` ${className}` : ''}`}>
	<slot />
</div>

<style is:global>
	.proj-brands-grid {
		--proj-brands-radius: var(--radius-none);
		--proj-brands-tile-radius: var(--radius-xs);
		--proj-brands-radial-x: 0%;
		--proj-brands-radial-y: 0%;
		--proj-brands-linear-dir: bottom right;
		--proj-brands-border-a: hsl(from var(--neutral-200) h s l / 0.16);
		--proj-brands-border-b: hsl(from var(--neutral-200) h s l / 0.02);
		--proj-brands-fill-a: hsl(from var(--neutral-900) h s l / 0.64);
		--proj-brands-fill-b: hsl(from var(--neutral-950) h s l / 0.92);

		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 0.9rem;
		width: min(820px, 100%);
		margin: 1.25rem auto 0;
		padding: 1.25rem 1.25rem 1.35rem;
		border-radius: var(--proj-brands-radius);

		border: 1px solid transparent;
		background:
			radial-gradient(
					circle at var(--proj-brands-radial-x) var(--proj-brands-radial-y),
					hsl(from var(--neutral-800) h s l / 0.22),
					transparent 60%
				),
			linear-gradient(180deg, var(--proj-brands-fill-a), var(--proj-brands-fill-b)),
			linear-gradient(135deg, var(--proj-brands-border-a), var(--proj-brands-border-b));
		background-origin: border-box;
		background-clip: padding-box, padding-box, border-box;
		backdrop-filter: blur(10px);
		box-shadow: 0 12px 28px rgb(0 0 0 / 0.22);
	}

	.proj-brands-grid .brand {
		--proj-brand-border-a: hsl(from var(--neutral-200) h s l / 0.16);
		--proj-brand-border-b: hsl(from var(--neutral-200) h s l / 0.03);
		--proj-brand-fill-a: hsl(from var(--neutral-900) h s l / 0.68);
		--proj-brand-fill-b: hsl(from var(--neutral-950) h s l / 0.86);

		display: flex;
		align-items: center;
		gap: 1rem;
		width: 100%;
		min-height: 74px;
		padding: 0.9rem 1.05rem;
		border-radius: var(--proj-brands-tile-radius);

		border: 1px solid transparent;
		background:
			linear-gradient(180deg, var(--proj-brand-fill-a), var(--proj-brand-fill-b)),
			linear-gradient(135deg, var(--proj-brand-border-a), var(--proj-brand-border-b));
		background-origin: border-box;
		background-clip: padding-box, border-box;
		box-shadow: 0 8px 14px rgb(0 0 0 / 0.12);

		transition:
			transform 220ms ease,
			box-shadow 220ms ease,
			background 220ms ease;
	}

	@media (hover: hover) and (pointer: fine) {
		.proj-brands-grid .brand:hover {
			--proj-brand-border-a: hsl(from var(--neutral-200) h s l / 0.22);
			--proj-brand-fill-a: hsl(from var(--neutral-900) h s l / 0.74);

			transform: translateY(-1px);
			box-shadow: 0 12px 22px rgb(0 0 0 / 0.16);
		}
	}

	.proj-brands-grid .brand svg {
		width: 2.6rem;
		height: 2.6rem;
		flex: none;
	}

	.proj-brands-grid .brand-name {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.08em;
		white-space: normal;
		line-height: 1.1;
	}

	@media (prefers-reduced-motion: reduce) {
		.proj-brands-grid .brand {
			transition: none;
		}

		@media (hover: hover) and (pointer: fine) {
			.proj-brands-grid .brand:hover {
				transform: none;
				box-shadow: none;
			}
		}
	}

	@media screen and (max-width: 767px) {
		.proj-brands-grid {
			grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
			gap: 0.75rem;
			padding: 1rem 0.95rem 1.1rem;
		}

		.proj-brands-grid .brand {
			min-height: 68px;
			padding: 0.8rem 0.9rem;
		}

		.proj-brands-grid .brand svg {
			width: 2.4rem;
			height: 2.4rem;
		}
	}
</style>

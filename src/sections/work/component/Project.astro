---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
	id: string;
	image: ImageMetadata;
	alt: string;
	projectId?: string;
}

const { id, image, alt, projectId } = Astro.props;
---

<div class="overlay-item proj-container" id={id}>
	<Image src={image} alt={alt} class="proj-img-mobl" />

	<div class="proj" data-proj-id={projectId}>
		<slot />
	</div>
</div>

<style is:global>
	.proj {
		.live-site-btn {
			border: 2px solid rgba(255, 192, 203, 0.6);
			padding: 0.75rem 4rem;
			display: flex;
			align-items: center;
			gap: 1rem;
			transition: border 0.25s;
			font-size: 18px;

			&:hover {
				border: 2px solid rgba(255, 192, 203, 1);
			}
			svg {
				width: 1.5rem;
				height: 1.5rem;
			}
		}

		h3 {
			font-size: 48px;
			font-weight: bold;
		}
		p {
			font-size: 18px;
			width: 900px;
			line-height: 2rem;
			color: var(--slate-50);
		}
		.motivation {
			text-align: center;
		}
		h3:first-of-type {
			margin-top: 6rem;
		}
		.brands-grid {
			font-size: 18px;
			display: flex;
			justify-content: space-between;
			width: 800px;

			.brands-col {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
		}
	}
</style>
<style>
	.proj-container {
		display: none;
	}
	.proj-container.active {
		display: block;
	}
	.proj {
		/* border: 1px solid green; */
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
	}
	.overlay-item {
		z-index: 1;
		display: none;
		position: relative;
	}
	.overlay-item.active {
		display: block;
	}
	.proj-img-mobl {
		width: 100%;
		height: auto;
		object-fit: contain;
		margin-top: 2rem;
	}
	@media screen and (min-width: 1024px) {
		.proj-img-mobl {
			display: none;
		}
	}
	@media screen and (max-width: 1023px) {
		.proj-img-mobl {
			display: none;
			opacity: 0;
			filter: blur(20px);
			transition: all var(--overlay-transition-time) ease;
		}
		.proj-container.active {
			.proj-img-mobl {
				display: block;
			}
		}
		.proj-container.animate-in {
			.proj-img-mobl {
				opacity: 1;
				filter: blur(0);
			}
		}
		.proj-container.animate-out {
			.proj-img-mobl {
			}
		}
	}
</style>

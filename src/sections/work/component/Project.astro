---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
	id: string;
	image: ImageMetadata;
	alt: string;
	projectId?: string;
}

const { id, image, alt, projectId } = Astro.props;
---

<div class="overlay-item proj-container" id={id}>
	<div class="proj-img-mobl-container">
		<Image src={image} alt={alt} class="proj-img-mobl" />
	</div>

	<slot />
</div>

<style is:global>
	.proj-img-mobl-container {
		position: relative;
	}
	html:not([active-proj='btsm']) {
		.overlay-open {
			.proj-img-mobl-container::after {
				content: '';
				position: absolute;
				inset: 0;
				opacity: 1;
				background: linear-gradient(transparent, black);
				transition: all var(--overlay-transition-time);
			}
		}
	}
	.overlay-open {
		.animate-in {
			.proj {
				opacity: 1;
				filter: blur(0px);
			}
		}
	}
	.proj {
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;
		opacity: 0;
		filter: blur(10px);
		transition: all 1s;
		transition-delay: 0.5s;

		.live-site-btn {
			padding: 0.75rem 4rem;
			display: flex;
			align-items: center;
			gap: 1rem;
			transition: all 0.3s;
			font-size: 18px;

			svg {
				width: 1.5rem;
				height: 1.5rem;
			}
		}

		h3 {
			font-size: 48px;
			font-weight: bold;
		}
		p {
			font-size: 18px;
			width: 700px;
			max-width: 95%;
			line-height: 2rem;
			font-family: 'Inter', sans-serif;
			font-weight: 250;
			margin: 0.5rem 0;
		}
		.motivation {
			text-align: center;
			margin: 0;
		}
		h3:first-of-type {
			margin-top: 6rem;
		}
		.brands-grid {
			font-size: 18px;
			display: flex;
			justify-content: space-between;
			width: 800px;
			max-width: 100%;
			margin: 1rem;

			.brands-col {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
		}
		.brand {
			display: flex;
			align-items: center;
			gap: 1rem;

			svg {
				width: 3rem;
				height: 3rem;
			}
		}
		.proj-footer-img {
			display: flex;
			justify-content: center;
			margin: 4rem 0;
			img {
				max-width: 90%;
			}
		}
	}
	.animate-out {
		.proj {
			display: none;
		}
	}
	@media screen and (max-width: 1023px) {
		.proj {
			transition-delay: unset;

			p {
				width: 650px;
			}
			.live-site-btn {
				margin-top: 2rem;
			}
			.brands-grid {
				flex-direction: column;
				gap: 2rem;
				width: 100%;

				.brands-col {
					display: grid;
					grid-template-columns: 1fr 1fr;
					row-gap: 1.75rem;
					border-top: 1px dotted grey;
					padding-top: 1.5rem;
					margin: 0 5rem;

					&:first-of-type {
						border-top: 0;
						padding-top: 0;
					}
				}
			}
		}
	}
	@media screen and (max-width: 767px) {
		.proj {
			.brands-grid {
				.brands-col {
					grid-template-columns: 1fr;
					margin: 0 1rem;
				}
			}
			p {
				/* margin: 0; */
			}
			h3 {
				font-size: 36px;
			}
		}
	}
</style>
<style>
	.proj-container {
		display: none;
	}
	.proj-container.active {
		display: block;
	}

	.overlay-item {
		z-index: 1;
		display: none;
		position: relative;
	}
	.overlay-item.active {
		display: block;
	}
	.proj-img-mobl {
		width: 100%;
		height: auto;
		object-fit: contain;
		margin-top: 2rem;
	}
	@media screen and (min-width: 1024px) {
		.proj-img-mobl {
			display: none;
		}
	}
	@media screen and (max-width: 1023px) {
		.proj-img-mobl {
			display: none;
			opacity: 0;
			filter: blur(20px);
			transition: all var(--overlay-transition-time) ease;
		}
		.proj-container.active {
			.proj-img-mobl {
				display: block;
			}
		}
		.proj-container.animate-in {
			.proj-img-mobl {
				opacity: 1;
				filter: blur(0);
			}
		}
		.proj-container.animate-out {
			.proj-img-mobl {
			}
		}
	}
</style>

---
import './dot-grid.css';
---

<section id="hero">
	<div class="section-dots">
		<div class="section-dots__wrap">
			<div data-dots-container-init="" class="dots-container">
				<div class="dot"></div>
			</div>
		</div>
	</div>
	<div class="attribute-wrapper">
		<h1>matthew van doff</h1>
		<h2>developer</h2>
		<h2>tinkerer</h2>
		<h2>good guy</h2>
	</div>
</section>

<style>
	#hero {
		height: 100vh;
		position: relative;

		.attribute-wrapper {
			position: absolute;
			right: 10vw;
			bottom: 22vh;
			display: flex;
			flex-direction: column;
			align-items: end;
		}
		h1,
		h2 {
			font-size: 50px;
			display: block;
			padding: 0.5rem 1rem;
			margin: 0;
			width: max-content;
		}
		h1 {
			margin-bottom: 0.5rem;
			color: var(--main-100);
		}
		h2 {
		}
		a {
			color: white;
		}
	}
</style>
